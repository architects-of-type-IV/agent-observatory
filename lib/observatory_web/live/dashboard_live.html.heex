<div
  class="h-screen bg-zinc-950 text-zinc-100 flex flex-col overflow-x-hidden"
  id="dashboard-root"
  phx-hook="KeyboardShortcuts"
>
  <%!-- Toast notifications --%>
  <div
    id="toast-container"
    phx-hook="Toast"
    class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"
  >
  </div>
  <%!-- Browser notifications --%>
  <div id="browser-notifications" phx-hook="BrowserNotifications"></div>
  <%!-- Header --%>
  <header class="sticky top-0 z-50 bg-zinc-900/95 backdrop-blur border-b border-zinc-800">
    <div class="px-2 py-1.5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <h1 class="text-sm font-bold tracking-tight text-zinc-200">Observatory</h1>
        <div class="flex items-center gap-1.5">
          <span class="relative flex h-1.5 w-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
          </span>
          <span class="text-zinc-600 text-[10px]">live</span>
        </div>
      </div>
      <ObservatoryWeb.Components.CommandComponents.fleet_status_bar
        swarm_state={@swarm_state}
        teams={@teams}
        events={@events}
        errors={@errors}
        now={@now}
        messages={@messages}
        protocol_stats={@protocol_stats}
        active_tasks={@active_tasks}
        tmux_sessions={@tmux_sessions}
        visible_events={@visible_events}
      />
    </div>

    <%!-- Search + Filters --%>
    <div class="px-2 pb-1.5 flex flex-col gap-1">
      <div class="obs-pill">
        <form phx-change="search_feed" class="flex-1">
          <input
            type="text"
            name="q"
            value={@search_feed}
            placeholder="Search events... (tool, command, file, message, team)"
            autocomplete="off"
            phx-debounce="150"
            class="w-full bg-zinc-800/80 px-2 py-1 text-[11px] text-zinc-300 placeholder-zinc-600 focus:outline-none border-none"
          />
        </form>
        <form phx-change="filter">
          <.stable_select id="filter-source-app" name="source_app" class="bg-zinc-800/80 border-l border-zinc-700/60 rounded-none px-1.5 py-1 text-[11px] text-zinc-300 focus:outline-none">
            <option value="">All Apps</option>
            <option
              :for={app <- unique_values(@events, :source_app)}
              value={app}
              selected={app == @filter_source_app}
            >
              {app}
            </option>
          </.stable_select>
          <.stable_select id="filter-event-type" name="event_type" class="bg-zinc-800/80 border-l border-zinc-700/60 rounded-none px-1.5 py-1 text-[11px] text-zinc-300 focus:outline-none">
            <option value="">All Events</option>
            <option
              :for={et <- unique_values(@events, :hook_event_type)}
              value={et}
              selected={to_string(et) == @filter_event_type}
            >
              {et}
            </option>
          </.stable_select>
        </form>
      </div>
      <%!-- Presets + Actions --%>
      <div class="flex items-center">
        <div class="flex items-center rounded overflow-hidden border border-zinc-700/60">
          <span class="text-[10px] text-zinc-600 px-1.5 py-1 bg-zinc-800/80">Presets</span>
          <button phx-click="apply_preset" phx-value-preset="failed_tools" class="text-[10px] px-2 py-1 bg-red-600/20 text-red-400 hover:bg-red-600/30 transition">Failed</button>
          <button phx-click="apply_preset" phx-value-preset="team_events" class="text-[10px] px-2 py-1 bg-cyan-600/15 text-cyan-400 hover:bg-cyan-600/25 transition">Teams</button>
          <button phx-click="apply_preset" phx-value-preset="slow" class="text-[10px] px-2 py-1 bg-amber-600/15 text-amber-400 hover:bg-amber-600/25 transition">Slow</button>
          <button phx-click="apply_preset" phx-value-preset="errors_only" class="text-[10px] px-2 py-1 bg-red-600/20 text-red-400 hover:bg-red-600/30 transition">Errors</button>
          <button
            :if={
              @filter_source_app || @filter_session_id || @filter_event_type || @search_feed != "" ||
                @search_sessions != ""
            }
            phx-click="clear_filters"
            onclick="document.querySelectorAll('#filter-selects-stable select').forEach(s => s.selectedIndex = 0)"
            class="text-[10px] px-2 py-1 bg-indigo-600/20 text-indigo-400 hover:bg-indigo-600/30 transition"
          >
            Reset
          </button>
        </div>
        <span class="flex-1" />
        <div class="obs-pill">
          <%!-- Export dropdown --%>
          <div class="relative flex" id="export-dropdown" phx-hook="ExportDropdown">
            <button id="export-button" class="obs-tip obs-tip-bottom text-[10px] px-2 py-1 bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 transition cursor-pointer" data-tip="Export events as JSON or CSV">Export</button>
            <div
              id="export-menu"
              class="hidden absolute right-0 mt-1 w-32 bg-zinc-800 border border-zinc-700 rounded-md shadow-lg z-10"
            >
              <a
                href={build_export_url(@filter_session_id, @search_feed, @filter_event_type, "json")}
                class="block px-3 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 transition"
                download
              >
                JSON
              </a>
              <a
                href={build_export_url(@filter_session_id, @search_feed, @filter_event_type, "csv")}
                class="block px-3 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 transition"
                download
              >
                CSV
              </a>
            </div>
          </div>
          <button phx-click="clear_events" class="obs-tip obs-tip-bottom text-[10px] px-2 py-1 bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 transition border-l border-zinc-700/60 cursor-pointer" data-tip="Clear all events">Clear</button>
          <button phx-click="toggle_shortcuts_help" class="obs-tip obs-tip-bottom text-[10px] px-2 py-1 bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 transition border-l border-zinc-700/60 cursor-pointer" data-tip="Keyboard shortcuts">?</button>
        </div>
      </div>
    </div>
  </header>

  <div class="flex flex-1 overflow-hidden">
    <%!-- ═══ Left Nav ═══ --%>
    <nav class="w-10 bg-zinc-900/50 border-r border-zinc-800 flex flex-col items-center py-2 gap-1 shrink-0">
      <.link
        patch="/"
        class={"obs-tip obs-tip-right flex items-center justify-center w-7 h-7 rounded transition #{if @nav_view == :pipeline, do: "bg-indigo-600/20 text-indigo-400", else: "text-zinc-600 hover:text-zinc-400 hover:bg-zinc-800"}"}
        data-tip="Pipeline"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" /></svg>
      </.link>
      <.link
        patch="/fleet"
        class={"obs-tip obs-tip-right flex items-center justify-center w-7 h-7 rounded transition #{if @nav_view == :fleet, do: "bg-indigo-600/20 text-indigo-400", else: "text-zinc-600 hover:text-zinc-400 hover:bg-zinc-800"}"}
        data-tip="Fleet Control"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
      </.link>
      <span class="flex-1" />
      <a href="/dev/dashboard" target="_blank" class="obs-tip obs-tip-right flex items-center justify-center w-7 h-7 rounded text-zinc-600 hover:text-zinc-400 hover:bg-zinc-800 transition" data-tip="LiveDashboard">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
      </a>
      <a href="/dev/mailbox" target="_blank" class="obs-tip obs-tip-right flex items-center justify-center w-7 h-7 rounded text-zinc-600 hover:text-zinc-400 hover:bg-zinc-800 transition" data-tip="Mailbox">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </a>
      <a href="/mcp" target="_blank" class="obs-tip obs-tip-right flex items-center justify-center w-7 h-7 rounded text-zinc-600 hover:text-zinc-400 hover:bg-zinc-800 transition" data-tip="MCP API">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
      </a>
    </nav>

    <%!-- ═══ Main Content Area ═══ --%>
    <main class="flex-1 flex flex-col overflow-hidden">
      <%!-- Agent focus view (overlay, triggered from agent actions) --%>
      <ObservatoryWeb.Components.AgentActivityComponents.agent_focus_view
        :if={@view_mode == :agent_focus && @selected_agent}
        agent={@selected_agent}
        events={agent_events(@events, @selected_agent[:agent_id])}
        tasks={agent_tasks(@active_tasks, @selected_agent[:agent_id])}
        expanded_events={@expanded_events}
        now={@now}
      />

      <%!-- ═══ View Content ═══ --%>
      <div :if={@view_mode != :agent_focus} class="flex-1 overflow-y-auto overflow-x-hidden p-2">
        <%!-- Pipeline View --%>
        <div :if={@nav_view == :pipeline} class="h-full -m-2 flex flex-col overflow-hidden">
          <%!-- Pipeline header bar --%>
          <div class="flex items-center justify-between px-3 py-1.5 border-b border-zinc-800 shrink-0">
            <h3 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Pipeline Board</h3>
            <div :if={@swarm_state.pipeline.total > 0} class="flex items-center rounded overflow-hidden">
              <span class="text-[9px] font-semibold px-1.5 py-0.5 bg-emerald-500/15 text-emerald-400">{@swarm_state.pipeline.completed} done</span>
              <span class="text-[9px] font-semibold px-1.5 py-0.5 bg-blue-500/15 text-blue-400">{@swarm_state.pipeline.in_progress} running</span>
              <span class="text-[9px] font-semibold px-1.5 py-0.5 bg-zinc-800 text-zinc-400">{@swarm_state.pipeline.pending} pending</span>
              <span :if={@swarm_state.pipeline.blocked > 0} class="text-[9px] font-semibold px-1.5 py-0.5 bg-amber-500/15 text-amber-400">{@swarm_state.pipeline.blocked} blocked</span>
              <span :if={@swarm_state.pipeline.failed > 0} class="text-[9px] font-semibold px-1.5 py-0.5 bg-red-500/15 text-red-400">{@swarm_state.pipeline.failed} failed</span>
            </div>
          </div>

          <%!-- Topology node info bar --%>
          <div :if={@selected_topology_node} class="px-3 py-1.5 bg-zinc-900/50 border-b border-zinc-800 flex items-center gap-4 text-[10px] shrink-0">
            <div class="flex items-center gap-2">
              <span class={"w-2 h-2 rounded-full #{if @selected_topology_node.status == :active, do: "bg-emerald-400", else: if(@selected_topology_node.status == :idle, do: "bg-zinc-500", else: "bg-zinc-700")}"} />
              <span class="font-mono text-zinc-300">{String.slice(@selected_topology_node.session_id, 0, 12)}</span>
            </div>
            <span :if={@selected_topology_node[:source_app]} class="text-zinc-400">{@selected_topology_node.source_app}</span>
            <span :if={@selected_topology_node[:model]} class="text-indigo-400">{@selected_topology_node.model}</span>
            <span :if={@selected_topology_node[:event_count]} class="text-zinc-500">{@selected_topology_node.event_count} events</span>
            <span :if={@selected_topology_node[:tool_count]} class="text-zinc-500">{@selected_topology_node.tool_count} tools</span>
            <span :if={@selected_topology_node[:duration]} class="text-zinc-500">{@selected_topology_node.duration}</span>
            <span :if={@selected_topology_node[:cwd]} class="font-mono text-zinc-600 truncate max-w-[200px]">{@selected_topology_node.cwd}</span>
            <span :if={@selected_topology_node[:last_tool]} class="text-cyan-500">{@selected_topology_node.last_tool}</span>
            <button phx-click="clear_topology_selection" class="ml-auto text-zinc-600 hover:text-zinc-400">x</button>
          </div>

          <%!-- Pipeline content --%>
          <div class="flex-1 overflow-hidden">
            <ObservatoryWeb.Components.PipelineComponents.pipeline_view
              swarm_state={@swarm_state}
              selected_dag_task={@selected_dag_task}
              show_add_project={@show_add_project}
              now={@now}
            />
          </div>
        </div>

        <%!-- Fleet Control View --%>
        <div :if={@nav_view == :fleet} class="h-full -m-2">
          <ObservatoryWeb.Components.CommandComponents.command_view
            swarm_state={@swarm_state}
            teams={@teams}
            events={@events}
            errors={@errors}
            now={@now}
            selected_command_agent={@selected_command_agent}
            selected_command_task={@selected_command_task}
            messages={@messages}
            protocol_stats={@protocol_stats}
            active_tasks={@active_tasks}
            analytics={@analytics}
            tmux_sessions={@tmux_sessions}
            feed_groups={@feed_groups}
            visible_events={@visible_events}
            selected_event={@selected_event}
            event_notes={@event_notes}
            expanded_sessions={@expanded_sessions}
            collapsed_fleet_teams={@collapsed_fleet_teams}
            comms_team_filter={@comms_team_filter}
            comms_agent_filter={@comms_agent_filter}
            activity_tab={@activity_tab}
          />
        </div>

      </div>

      <%!-- ═══ Detail Panel (bottom drawer) ═══ --%>
      <div
        :if={@selected_event || @selected_task || @selected_agent}
        class="bg-zinc-900/70 border-t border-zinc-800 overflow-y-auto shrink-0 max-h-[40vh]"
      >
        <ObservatoryWeb.Components.DetailPanelComponents.detail_panel
          selected_event={@selected_event}
          selected_task={@selected_task}
          selected_agent={@selected_agent}
          events={@events}
          active_tasks={@active_tasks}
          event_notes={@event_notes}
          expanded_events={@expanded_events}
          now={@now}
        />
      </div>

      <%!-- ═══ Tmux Multi-Panel ═══ --%>
      <div
        :if={@tmux_panels != []}
        class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm"
        phx-click="close_all_tmux"
      >
        <div
          class="w-[92vw] max-w-6xl h-[85vh] bg-zinc-900 border border-zinc-700 rounded-xl shadow-2xl flex flex-col overflow-hidden"
          onclick="event.stopPropagation()"
        >
          <%!-- Header: tabs + controls --%>
          <div class="flex items-center justify-between px-3 py-1.5 border-b border-zinc-800 bg-zinc-900/95 shrink-0">
            <div class="flex items-center gap-1 overflow-x-auto">
              <span class="text-[10px] font-semibold text-amber-500 uppercase tracking-wider mr-2 shrink-0">tmux</span>
              <%= for session <- @tmux_panels do %>
                <% is_active = session == @active_tmux_session %>
                <button
                  phx-click="switch_tmux_tab"
                  phx-value-session={session}
                  class={"flex items-center gap-1.5 px-2.5 py-1 rounded text-[11px] font-mono transition shrink-0 cursor-pointer #{if is_active, do: "bg-amber-500/15 text-amber-300 border border-amber-500/30", else: "text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800"}"}
                >
                  <span class={"w-1.5 h-1.5 rounded-full #{if is_active, do: "bg-emerald-400", else: "bg-zinc-600"}"}></span>
                  {session}
                </button>
              <% end %>
            </div>
            <div class="flex items-center gap-1.5 shrink-0">
              <span class="text-[9px] text-zinc-600 font-mono">{length(@tmux_panels)} open</span>
              <button
                phx-click="toggle_tmux_layout"
                class={"obs-btn obs-btn-muted text-[10px] #{if @tmux_layout == :tiled, do: "!bg-amber-500/15 !text-amber-400", else: ""}"}
                title={if @tmux_layout == :tabs, do: "Switch to tiled", else: "Switch to tabs"}
              >
                {if @tmux_layout == :tabs, do: "Tile", else: "Tabs"}
              </button>
              <button
                :if={@active_tmux_session}
                phx-click="kill_tmux_session"
                class="obs-btn obs-btn-danger text-[10px]"
                data-confirm={"Kill session #{@active_tmux_session}?"}
              >
                Kill
              </button>
              <button phx-click="disconnect_tmux" class="obs-btn obs-btn-muted text-[10px]" title="Close active tab">
                Close Tab
              </button>
              <button phx-click="close_all_tmux" class="obs-btn obs-btn-muted text-[10px]" title="Close all">
                x
              </button>
            </div>
          </div>

          <%!-- Terminal content --%>
          <%= if @tmux_layout == :tabs do %>
            <%!-- Tabbed: single active pane --%>
            <div class="flex-1 overflow-y-auto p-4 bg-zinc-950">
              <pre class="text-[12px] font-mono text-zinc-300 leading-relaxed whitespace-pre-wrap">{@tmux_output}</pre>
            </div>
          <% else %>
            <%!-- Tiled: grid of all open panes --%>
            <% cols = if length(@tmux_panels) <= 2, do: "grid-cols-1 md:grid-cols-2", else: "grid-cols-2" %>
            <div class={"flex-1 grid #{cols} gap-px bg-zinc-800 overflow-hidden"}>
              <%= for session <- @tmux_panels do %>
                <% is_active = session == @active_tmux_session %>
                <div
                  class={"flex flex-col overflow-hidden #{if is_active, do: "ring-1 ring-amber-500/40", else: ""}"}
                  phx-click="switch_tmux_tab"
                  phx-value-session={session}
                >
                  <div class={"flex items-center justify-between px-2 py-1 shrink-0 #{if is_active, do: "bg-amber-500/10", else: "bg-zinc-900/80"}"}>
                    <span class="text-[10px] font-mono text-zinc-400">{session}</span>
                    <span class={"w-1.5 h-1.5 rounded-full #{if is_active, do: "bg-emerald-400", else: "bg-zinc-600"}"}></span>
                  </div>
                  <div class="flex-1 overflow-y-auto p-2 bg-zinc-950">
                    <pre class="text-[10px] font-mono text-zinc-400 leading-relaxed whitespace-pre-wrap">{Map.get(@tmux_outputs, session, "")}</pre>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%!-- Input (always targets active session) --%>
          <div :if={@active_tmux_session} class="px-4 py-2 border-t border-zinc-800 bg-zinc-900/95 shrink-0">
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-amber-500 font-mono shrink-0">{@active_tmux_session} ></span>
              <div id="tmux-input-stable" phx-update="ignore" class="flex-1">
                <form phx-submit="send_tmux_keys" class="flex gap-2">
                  <input
                    type="text"
                    name="keys"
                    placeholder="Send keys..."
                    autocomplete="off"
                    class="flex-1 obs-input"
                  />
                  <button type="submit" class="obs-btn obs-btn-primary">Send</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

    </main>

    <%!-- ═══ Sidebar Toggle ═══ --%>
    <button
      phx-click="toggle_sidebar"
      class="w-5 bg-zinc-900/30 border-l border-zinc-800/60 flex items-center justify-center hover:bg-zinc-800/60 transition shrink-0 text-zinc-700 hover:text-zinc-400"
      title={if @sidebar_collapsed, do: "Show sidebar", else: "Hide sidebar"}
    >
      <span class="text-[9px]">{if @sidebar_collapsed, do: "<", else: ">"}</span>
    </button>

    <%!-- ═══ Right Sidebar ═══ --%>
    <aside class={["bg-[rgb(24,24,27)]/50 border-l border-zinc-800 shrink-0 transition-all flex flex-col", if(@sidebar_collapsed, do: "w-0 overflow-hidden", else: "w-60")]}>
      <div class="p-2 flex-1 overflow-y-auto">
        <%!-- Teams Section --%>
        <div :if={@has_teams} class="mb-3">
          <h2 class="obs-section-title px-1 mb-1.5">
            Teams <span class="font-mono">({length(@teams)})</span>
          </h2>
          <div class="space-y-1">
            <div
              :for={team <- @teams}
              class={"obs-sidebar-item #{if @selected_team == team.name, do: "active", else: ""}"}
              phx-click="select_team"
              phx-value-name={team.name}
            >
              <div class="flex items-center justify-between mb-0.5">
                <span class="si-title font-semibold text-zinc-200">{team.name}</span>
                <span class="si-meta font-mono">{length(team.members)}</span>
              </div>

              <%!-- Task progress bar --%>
              <% task_total = length(team.tasks) %>
              <% task_done = Enum.count(team.tasks, fn t -> t[:status] == "completed" end) %>
              <div :if={task_total > 0} class="mb-1">
                <div class="flex items-center justify-between si-meta font-mono mb-0.5">
                  <span>tasks</span>
                  <span>{task_done}/{task_total}</span>
                </div>
                <div class="h-1 bg-zinc-800 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-emerald-500 rounded-full transition-all"
                    style={"width: #{if task_total > 0, do: round(task_done / task_total * 100), else: 0}%"}
                  >
                  </div>
                </div>
              </div>

              <%!-- Members --%>
              <div class="space-y-0.5">
                <div :for={m <- team.members} class="flex items-center gap-1.5">
                  <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{member_status_color(m[:status])}"}>
                  </span>
                  <span class="si-title truncate">{m[:name] || "?"}</span>
                  <span :if={m[:agent_type]} class="si-meta ml-auto">
                    {m[:agent_type]}
                  </span>
                </div>
              </div>

              <%!-- Team Controls --%>
              <div class="flex gap-1 mt-1">
                <button
                  phx-click="inspect_team"
                  phx-value-team={team.name}
                  class="flex-1 obs-btn obs-btn-muted !text-[9px] !py-0.5"
                >
                  Inspect
                </button>
                <button
                  phx-click="send_team_broadcast"
                  phx-value-team={team.name}
                  phx-value-content="status"
                  class="obs-btn !text-[9px] !py-0.5 bg-cyan-600/15 text-cyan-400 hover:bg-cyan-600/25"
                  title={"Ping all agents in #{team.name}"}
                >
                  Ping
                </button>
              </div>
            </div>
          </div>
        </div>

        <%!-- Sessions Section --%>
        <div>
          <div class="flex items-center justify-between mb-1.5 px-1">
            <h2 class="obs-section-title">
              {if @has_teams, do: "Standalone", else: "Sessions"} <span class="font-mono">({length(@sessions)}<span :if={
                length(@sessions) != @total_sessions
              }>/{@total_sessions}</span>)</span>
            </h2>
          </div>
          <form phx-change="search_sessions" class="mb-1.5 px-0.5">
            <input
              type="text"
              name="q"
              value={@search_sessions}
              placeholder="Search sessions..."
              autocomplete="off"
              phx-debounce="150"
              class="w-full obs-input"
            />
          </form>
          <div class="space-y-0.5">
            <div
              :for={s <- @sessions}
              class={"obs-sidebar-item #{if @filter_session_id == s.session_id, do: "active", else: ""}"}
              phx-click="filter_session"
              phx-value-sid={s.session_id}
            >
              <div class="flex items-center gap-1.5">
                <% {bg, _border, _text} = session_color(s.session_id) %>
                <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{bg} #{if s.ended?, do: "opacity-30", else: ""}"}>
                </span>
                <span class="si-title truncate">{s.source_app}</span>
                <span class="si-meta font-mono">{short_session(s.session_id)}</span>
                <ObservatoryWeb.ObservatoryComponents.model_badge model={s.model} />
              </div>
              <div class="si-meta ml-3 flex items-center gap-1.5 font-mono">
                <span>{s.event_count}ev</span>
                <span>{session_duration(s.first_event, @now)}</span>
                <span :if={s.cwd} class="truncate">{abbreviate_cwd(s.cwd)}</span>
              </div>
            </div>
          </div>
        </div>

        <%!-- Message Composer (in sidebar, below sessions) --%>
        <div :if={@teams != []} class="mt-3 pt-3 border-t border-zinc-800">
          <h2 class="obs-section-title px-1 mb-1.5">Message</h2>
          <div phx-update="ignore" id="message-composer-stable" phx-hook="ClearFormOnSubmit">
            <ObservatoryWeb.Components.TeamMessageComponents.message_composer
              teams={@teams}
              selected_message_target={@selected_message_target}
            />
          </div>
        </div>
      </div>
    </aside>
  </div>

  <%!-- Inspector Drawer --%>
  <ObservatoryWeb.Components.TeamInspectorComponents.inspector_drawer
    inspected_teams={@inspected_teams}
    inspector_layout={@inspector_layout}
    inspector_maximized={@inspector_maximized}
    inspector_size={@inspector_size}
    now={@now}
  />

  <%!-- Tmux Maximized View --%>
  <ObservatoryWeb.Components.TeamTmuxComponents.tmux_view
    :if={@inspector_maximized && @inspected_teams != []}
    inspected_teams={@inspected_teams}
    output_mode={@output_mode}
    agent_toggles={@agent_toggles}
    live_events={@inspector_events}
    now={@now}
  />
</div>

<%!-- Create Task Modal --%>
<div
  :if={@show_create_task_modal}
  class="fixed inset-0 bg-black/50 flex items-center justify-center z-50"
  phx-click="toggle_create_task_modal"
>
  <div
    class="bg-zinc-900 border border-zinc-700 rounded-lg shadow-xl max-w-lg w-full mx-4"
    phx-click="stop"
  >
    <div class="px-4 py-3 border-b border-zinc-800 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-zinc-200">Create New Task</h2>
      <button
        phx-click="toggle_create_task_modal"
        class="text-zinc-500 hover:text-zinc-300 transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
      </button>
    </div>
    <form phx-submit="create_task" class="px-4 py-3 space-y-3">
      <div>
        <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Subject</label>
        <input
          type="text"
          name="subject"
          required
          class="w-full obs-input text-xs py-1.5"
          placeholder="Add new feature..."
        />
      </div>
      <div>
        <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Description</label>
        <textarea
          name="description"
          required
          rows="3"
          class="w-full obs-input text-xs py-1.5"
          placeholder="Detailed description of the task..."
        ></textarea>
      </div>
      <div>
        <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Assign To</label>
        <.stable_select id="select-task-owner" name="owner" class="w-full obs-select text-xs py-1.5">
          <option value="">Unassigned</option>
          <option
            :for={member <- if @sel_team, do: @sel_team.members, else: []}
            value={member[:agent_id] || member[:name]}
          >
            {member[:name] || member[:agent_id]}
          </option>
        </.stable_select>
      </div>
      <input type="hidden" name="team" value={@selected_team} />
      <div class="flex justify-end gap-2 pt-2">
        <button
          type="button"
          phx-click="toggle_create_task_modal"
          class="obs-btn obs-btn-muted"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="obs-btn obs-btn-primary"
        >
          Create Task
        </button>
      </div>
    </form>
  </div>
</div>

<%!-- Keyboard Shortcuts Help Modal --%>
<div
  :if={@show_shortcuts_help}
  class="fixed inset-0 bg-black/50 flex items-center justify-center z-50"
  phx-click="toggle_shortcuts_help"
>
  <div
    class="bg-zinc-900 border border-zinc-700 rounded-lg shadow-xl max-w-md w-full mx-4"
    phx-click="stop"
  >
    <div class="px-4 py-3 border-b border-zinc-800 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-zinc-200">Keyboard Shortcuts</h2>
      <button
        phx-click="toggle_shortcuts_help"
        class="text-zinc-500 hover:text-zinc-300 transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
      </button>
    </div>
    <div class="px-4 py-3 space-y-3">
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">
          Navigation
        </h3>
        <div class="space-y-1 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Switch views (1-6)</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              1-6
            </kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Focus search</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              f
            </kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Clear selection</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              Esc
            </kbd>
          </div>
        </div>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Feed</h3>
        <div class="space-y-1 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Next event</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              j
            </kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Previous event</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              k
            </kbd>
          </div>
        </div>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Help</h3>
        <div class="space-y-1 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-zinc-400">Show this help</span>
            <kbd class="px-2 py-0.5 bg-zinc-800 border border-zinc-700 rounded text-zinc-300 font-mono">
              ?
            </kbd>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
