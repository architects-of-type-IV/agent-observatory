<%
  detail = @stats[:mailbox_detail] || []
  agent_name_map = build_agent_name_map(@teams)
%>
<div>
  <div class="px-2 py-1.5 border-b border-zinc-800/50">
    <h5 class="text-[9px] font-semibold uppercase tracking-wider text-zinc-500">
      Mailbox <span class="text-zinc-600 normal-case font-normal">{length(detail)} agents</span>
    </h5>
  </div>
  <%= if detail == [] do %>
    <p class="text-[9px] text-zinc-600 px-2 py-2">No mailbox entries</p>
  <% else %>
    <div>
      <div :for={entry <- detail}>
        <%
          key = "mailbox:#{entry.agent_id}"
          expanded = MapSet.member?(@expanded_items, key)
          agent_label = resolve_agent_label(entry.agent_id, agent_name_map)
        %>
        <div
          class="px-2 py-1 flex items-center gap-1.5 cursor-pointer hover:bg-zinc-800/30 transition"
          phx-click="toggle_protocol_item"
          phx-value-id={key}
        >
          <svg class={"w-2.5 h-2.5 text-zinc-600 transition-transform #{if expanded, do: "rotate-90"}"} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <div class="flex-1 min-w-0">
            <span class="text-[9px] font-mono text-zinc-400 truncate" title={entry.agent_id}>{agent_label}</span>
          </div>
          <span class="text-[9px] text-zinc-600 tabular-nums">{entry.total}</span>
          <%= if entry.unread > 0 do %>
            <span class="text-[9px] tabular-nums text-amber-400 font-semibold">{entry.unread} unread</span>
          <% else %>
            <span class="text-[9px] text-emerald-500">read</span>
          <% end %>
        </div>
        <%= if expanded do %>
          <div class="px-5 pb-1.5 pt-0.5">
            <%= if (entry[:recent_messages] || []) == [] do %>
              <div class="text-[9px] text-zinc-700">No messages</div>
            <% else %>
              <div class="space-y-px">
                <div :for={msg <- entry[:recent_messages] || []} class="flex gap-1.5 py-0.5">
                  <span class={"w-1 h-1 rounded-full mt-1 shrink-0 #{if msg.read, do: "bg-zinc-700", else: "bg-amber-400"}"}></span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-1">
                      <span class="text-[9px] font-mono text-zinc-400">{resolve_agent_label(msg.from, agent_name_map)}</span>
                      <span class="text-[9px] text-zinc-700">{format_timestamp(msg.timestamp)}</span>
                      <span :if={msg.read} class="text-[8px] text-emerald-600">read</span>
                    </div>
                    <p class="text-[9px] text-zinc-500 truncate">{msg.content}</p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
