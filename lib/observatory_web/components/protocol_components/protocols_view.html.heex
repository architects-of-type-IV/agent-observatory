<%
  stats = @protocol_stats
  total_unread = get_in(stats, [:mailbox, :total_unread]) || 0
  total_queue = get_in(stats, [:command_queue, :total_pending]) || 0
  messages = assigns[:mailbox_messages] || []
  agent_name_map = build_agent_name_map(@teams)
%>
<div class="flex gap-0 h-full">
  <%!-- Left: Summary + Channel Details --%>
  <div class="w-72 shrink-0 border-r border-border bg-base/30 flex flex-col overflow-hidden">
    <%!-- Counters --%>
    <div class="flex items-stretch border-b border-border text-[10px] shrink-0">
      <span class="flex-1 text-center px-2 py-1.5 text-interactive font-semibold">{length(messages)} messages</span>
      <span class="flex-1 text-center px-2 py-1.5 text-brand font-semibold border-l border-border">{total_unread} unread</span>
      <span class="flex-1 text-center px-2 py-1.5 text-low font-semibold border-l border-border">{total_queue} queued</span>
    </div>

    <%!-- Scrollable detail panels --%>
    <div class="flex-1 overflow-y-auto">
      <.traces_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
      <.mailbox_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
      <.queue_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
    </div>
  </div>

  <%!-- Right: Conversation Timeline --%>
  <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
    <div class="px-3 py-1.5 border-b border-border shrink-0 flex items-center justify-between">
      <h3 class="text-[10px] font-semibold text-low uppercase tracking-wider">Conversation Timeline</h3>
      <span class="text-[9px] text-muted">{length(messages)} messages</span>
    </div>

    <%= if messages == [] do %>
      <div class="flex-1 flex items-center justify-center p-6">
        <div class="text-center max-w-xs">
          <p class="text-[11px] text-low mb-2">No messages yet</p>
          <p class="text-[10px] text-muted leading-relaxed">
            Send a message from the Fleet view or via the MCP API to see conversations here.
          </p>
          <div class="mt-4 space-y-2 text-left">
            <p class="text-[9px] text-muted uppercase tracking-wider">How to test</p>
            <div class="text-[10px] text-low space-y-1">
              <p>1. Go to <span class="text-interactive">/fleet</span> -- select a target and send a message from the command bar</p>
              <p>2. Click <span class="text-interactive">Msg</span> on any agent card to message them directly</p>
              <p>3. Use the <span class="text-interactive">Message</span> composer in the sidebar to target teams or agents</p>
              <p>4. Come back here to see the conversation flow</p>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <div class="flex-1 overflow-y-auto">
        <div class="divide-y divide-border/30">
          <%= for msg <- messages do %>
            <% from_label = resolve_agent_label(msg.from, agent_name_map) %>
            <% to_label = resolve_agent_label(msg.to, agent_name_map) %>
            <div class="px-4 py-2.5 hover:bg-raised/20 transition">
              <%!-- Header: from -> to + timestamp --%>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[10px] font-semibold text-high">{from_label}</span>
                <svg class="w-3 h-3 text-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
                <span class="text-[10px] font-semibold text-high">{to_label}</span>
                <span class="flex-1" />
                <span class={"text-[9px] px-1.5 py-0.5 rounded #{if msg.read, do: "text-success", else: "text-brand bg-brand/10"}"}>{if msg.read, do: "read", else: "unread"}</span>
                <span class="text-[9px] text-muted font-mono tabular-nums">{format_timestamp(msg.timestamp)}</span>
              </div>
              <%!-- Content --%>
              <p class="text-[11px] text-default leading-relaxed pl-0.5">{msg.content}</p>
              <%!-- Delivery info --%>
              <div class="flex items-center gap-3 mt-1 pl-0.5">
                <div class="flex items-center gap-1">
                  <span class="w-1 h-1 rounded-full bg-success" />
                  <span class="text-[9px] text-muted">mailbox</span>
                </div>
                <span :if={msg.metadata[:via_gateway]} class="text-[9px] text-muted">via gateway</span>
                <span :if={msg.type && msg.type != :text} class="text-[9px] text-muted">{msg.type}</span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
