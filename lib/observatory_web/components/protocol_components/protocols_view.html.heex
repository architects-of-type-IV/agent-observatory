<%
  traces = Observatory.ProtocolTracker.get_traces() |> Enum.take(50)
  stats = @protocol_stats
  total_unread = get_in(stats, [:mailbox, :total_pending]) || 0
  total_queue = get_in(stats, [:command_queue, :total_pending]) || 0
%>
<div class="flex gap-0 h-full">
  <%!-- Left: Summary + Channel Details --%>
  <div class="w-72 shrink-0 border-r border-zinc-800 bg-zinc-900/30 flex flex-col overflow-hidden">
    <%!-- Counters --%>
    <div class="flex items-stretch border-b border-zinc-800 text-[10px] shrink-0">
      <span class="flex-1 text-center px-2 py-1.5 text-indigo-400 font-semibold" title="Protocol traces (SendMessage, TeamCreate, SubagentStart)">{stats[:traces] || 0} traces</span>
      <span class="flex-1 text-center px-2 py-1.5 text-amber-400 font-semibold border-l border-zinc-800" title={"#{total_unread} unread messages, #{total_queue} pending commands"}>{total_unread + total_queue} pending</span>
      <span class="flex-1 text-center px-2 py-1.5 text-zinc-500 font-semibold border-l border-zinc-800" title={"#{get_in(stats, [:mailbox, :agents]) || 0} agents, #{get_in(stats, [:command_queue, :sessions]) || 0} sessions"}>{(get_in(stats, [:mailbox, :agents]) || 0) + (get_in(stats, [:command_queue, :sessions]) || 0)} channels</span>
    </div>

    <%!-- Scrollable detail panels --%>
    <div class="flex-1 overflow-y-auto">
      <%!-- Traces --%>
      <.traces_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
      <%!-- Mailbox --%>
      <.mailbox_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
      <%!-- CommandQueue --%>
      <.queue_detail stats={stats} expanded_items={@expanded_items} teams={@teams} />
    </div>
  </div>

  <%!-- Right: Message Flow --%>
  <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
    <div class="px-3 py-1.5 border-b border-zinc-800 shrink-0 flex items-center justify-between">
      <h3 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Message Flow</h3>
      <span class="text-[9px] text-zinc-600">{length(traces)} traces</span>
    </div>

    <%= if traces == [] do %>
      <div class="flex-1 flex items-center justify-center p-6">
        <div class="text-center max-w-xs">
          <p class="text-[11px] text-zinc-500 mb-2">No message traces yet</p>
          <p class="text-[10px] text-zinc-600 leading-relaxed">
            Traces appear when agents use SendMessage, TeamCreate, or spawn subagents.
            Each trace shows the message path through the protocol stack: HTTP event -> Mailbox ETS -> CommandQueue filesystem.
          </p>
          <div class="mt-4 border border-zinc-800 rounded p-3 text-left">
            <p class="text-[9px] text-zinc-600 uppercase tracking-wider mb-2">Example trace</p>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-[9px] text-zinc-600 font-mono w-12">just now</span>
              <span class="px-1 py-0 rounded text-[9px] bg-indigo-500/15 text-indigo-400">message</span>
              <span class="text-[9px] font-mono text-zinc-500">operator</span>
              <span class="text-[9px] text-zinc-600">-></span>
              <span class="text-[9px] font-mono text-zinc-500">lead@team</span>
            </div>
            <div class="flex gap-3 ml-14">
              <div class="flex items-center gap-1 text-[9px]">
                <span class="w-1 h-1 rounded-full bg-emerald-400"></span>
                <span class="text-zinc-600">http</span>
                <span class="text-emerald-500">received</span>
              </div>
              <div class="flex items-center gap-1 text-[9px]">
                <span class="w-1 h-1 rounded-full bg-emerald-400"></span>
                <span class="text-zinc-600">mailbox</span>
                <span class="text-emerald-500">delivered</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <div class="flex-1 overflow-y-auto divide-y divide-zinc-800/50">
        <.trace_row :for={trace <- traces} trace={trace} now={@now} />
      </div>
    <% end %>
  </div>
</div>
