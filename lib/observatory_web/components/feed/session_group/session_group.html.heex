<% expanded = MapSet.member?(@expanded_sessions, @group.session_id) %>
<div class={[
  "rounded-lg overflow-hidden",
  depth_style(@depth),
  if(@group.is_active, do: "ring-1 ring-success/20", else: "")
]}>
  <%!-- Session Header (always visible, clickable to toggle) --%>
  <div
    class={[
      "px-2.5 py-1.5 flex items-center gap-2 cursor-pointer select-none",
      if(@group.is_active, do: "bg-raised/60 hover:bg-raised/80", else: "bg-base/40 hover:bg-base/60")
    ]}
    phx-click="toggle_session_collapse"
    phx-value-session_id={@group.session_id}
  >
    <%!-- Collapse indicator + Status dot --%>
    <span class="text-muted text-[10px] font-mono w-3 shrink-0">
      {if expanded, do: "-", else: "+"}
    </span>
    <span class={[
      "w-1.5 h-1.5 rounded-full shrink-0",
      if(@group.is_active, do: "bg-success animate-pulse", else: "bg-highlight")
    ]} />

    <%!-- Agent name --%>
    <span class="text-xs font-medium text-high">
      {agent_display_name(@group)}
    </span>

    <%!-- Role --%>
    <.role_badge role={@group.role} />

    <%!-- Session ID --%>
    <span class="text-[10px] font-mono text-muted" title={@group.session_id}>
      {short_session(@group.session_id)}
    </span>

    <%!-- Model --%>
    <.model_badge :if={@group.model} model={@group.model} />

    <%!-- Permission mode --%>
    <span
      :if={@group.permission_mode}
      class="text-[10px] font-mono text-muted"
    >
      {permission_label(@group.permission_mode)}
    </span>

    <%!-- Source app --%>
    <span :if={@group.source_app} class="text-[10px] font-mono text-muted">
      {String.upcase(@group.source_app || "")}
    </span>

    <span class="flex-1" />

    <%!-- Stats (condensed) --%>
    <span class="text-[10px] font-mono text-muted flex items-center gap-1.5">
      <span :if={@group.turn_count > 0}>{@group.turn_count}t</span>
      <span :if={@group.tool_count > 0}>{@group.tool_count}x</span>
      <span :if={@group.subagent_count > 0} class="text-cyan-600">{@group.subagent_count}s</span>
    </span>

    <%!-- Time range --%>
    <span :if={@group.start_time} class="text-[10px] font-mono text-muted">
      {format_time(@group.start_time)}{if @group.end_time && @group.end_time != @group.start_time, do: "-#{format_time(@group.end_time)}", else: ""}
    </span>

    <%!-- CWD --%>
    <span :if={@group.cwd} class="text-[10px] font-mono text-muted truncate max-w-[160px]" title={@group.cwd}>
      {abbreviate_cwd(@group.cwd)}
    </span>
  </div>

  <%!-- Collapsible body --%>
  <div :if={expanded}>
    <%!-- Session Start Banner --%>
    <div
      :if={@group.session_start}
      class="px-2.5 py-1 border-b border-border flex items-center gap-2"
    >
      <span class="text-[10px] font-mono text-success">start</span>
      <span class="text-[10px] font-mono text-low">
        {format_time(@group.session_start.inserted_at)}
      </span>
      <span :if={@group.model} class="text-[10px] font-mono text-muted">
        {@group.model}
      </span>
      <span :if={@group.cwd} class="text-[10px] font-mono text-muted truncate" title={@group.cwd}>
        {abbreviate_cwd(@group.cwd)}
      </span>
    </div>

    <%!-- Render turns --%>
    <div class="space-y-0">
      <.render_item
        :for={item <- @group.turns}
        item={item}
        selected_event={@selected_event}
        event_notes={@event_notes}
        expanded_sessions={@expanded_sessions}
        now={@now}
      />
    </div>

    <%!-- Session End / Stop Banner --%>
    <div
      :if={@group.session_end || @group.stop_event}
      class="px-2.5 py-1 border-t border-border flex items-center gap-2"
    >
      <span class="text-[10px] font-mono text-error">
        {if @group.session_end, do: "end", else: "stop"}
      </span>
      <span class="text-[10px] font-mono text-low">
        {format_time((@group.session_end || @group.stop_event).inserted_at)}
      </span>
      <span :if={@group.total_duration_ms} class="text-[10px] font-mono text-muted">
        {format_duration(@group.total_duration_ms)}
      </span>
      <span :if={session_end_reason(@group)} class="text-[10px] font-mono text-muted">
        {session_end_reason(@group)}
      </span>
    </div>

    <%!-- Active indicator --%>
    <div
      :if={@group.is_active && @group.end_time}
      class="px-2.5 py-0.5 border-t border-border flex items-center gap-1.5"
    >
      <span class="w-1 h-1 rounded-full bg-success animate-pulse" />
      <span class="text-[10px] font-mono text-muted">
        {relative_time(@group.end_time, @now)}
      </span>
    </div>
  </div>
</div>
