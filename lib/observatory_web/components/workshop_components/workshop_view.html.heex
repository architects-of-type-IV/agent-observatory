<%
  wc = ObservatoryWeb.Components.WorkshopComponents
  selected = wc.find_agent(@ws_agents, @ws_selected_agent)
  tree = wc.spawn_tree_html(@ws_agents, @ws_spawn_links)
%>
<div class="h-full -m-2 flex flex-col overflow-hidden">
  <%!-- Presets bar --%>
  <div class="flex items-center px-2 py-1 border-b border-zinc-800 gap-2 shrink-0">
    <div class="flex items-center rounded overflow-hidden border border-zinc-700/60">
      <span class="text-[10px] text-zinc-600 px-1.5 py-1 bg-zinc-800/80">Presets</span>
      <button phx-click="ws_preset" phx-value-name="dag" class="text-[10px] px-2 py-1 bg-cyan-600/10 text-cyan-400 hover:bg-cyan-600/20 transition cursor-pointer">DAG Pipeline</button>
      <button phx-click="ws_preset" phx-value-name="solo" class="text-[10px] px-2 py-1 bg-emerald-600/10 text-emerald-400 hover:bg-emerald-600/20 transition cursor-pointer">Solo Builder</button>
      <button phx-click="ws_preset" phx-value-name="research" class="text-[10px] px-2 py-1 bg-violet-600/10 text-violet-400 hover:bg-violet-600/20 transition cursor-pointer">Research Squad</button>
      <button phx-click="ws_preset" phx-value-name="review" class="text-[10px] px-2 py-1 bg-amber-600/10 text-amber-400 hover:bg-amber-600/20 transition cursor-pointer">Review Chain</button>
      <button phx-click="ws_clear" class="text-[10px] px-2 py-1 bg-red-600/10 text-red-400 hover:bg-red-600/20 transition cursor-pointer">Clear</button>
    </div>
    <span class="flex-1" />
    <span class="text-[10px] text-zinc-600">Drag green ports for spawn hierarchy, cyan ports for comm rules</span>
  </div>

  <div class="flex flex-1 overflow-hidden">
    <%!-- Canvas area --%>
    <div class="flex-1 flex flex-col overflow-hidden">
      <%!-- Canvas toolbar --%>
      <div class="px-3 py-1.5 border-b border-zinc-800 flex items-center gap-2 bg-zinc-900/30 shrink-0">
        <h3 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Team Builder</h3>
        <span class="w-px h-3 bg-zinc-800" />
        <button phx-click="ws_add_agent" class="obs-btn obs-btn-success">+ Agent</button>
        <span class="flex-1" />
        <span class="text-[10px] text-zinc-500">
          <span class="font-bold text-zinc-200">{length(@ws_agents)}</span> agents
          <span class="mx-1 text-zinc-700">|</span>
          <span>{length(@ws_spawn_links)}</span> spawn links
          <span class="mx-1 text-zinc-700">|</span>
          <span>{length(@ws_comm_rules)}</span> comm rules
        </span>
      </div>

      <%!-- Canvas with JS hook --%>
      <div id="workshop-canvas-hook" phx-hook="WorkshopCanvas" phx-update="ignore" class="flex-1 relative overflow-auto" style="background: #09090b; background-image: radial-gradient(circle, rgba(63,63,70,0.15) 1px, transparent 1px); background-size: 24px 24px;">
        <svg class="ws-lines" style="position:absolute;inset:0;pointer-events:none;z-index:1;" width="100%" height="100%"></svg>
        <div class="ws-canvas" style="position:relative;min-width:100%;min-height:100%;">
          <div :if={@ws_agents == []} class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center pointer-events-none">
            <div class="text-xs font-medium text-zinc-500 mb-1">Click "+ Agent" or use a preset to start</div>
            <div class="text-[10px] text-zinc-600 leading-relaxed">Add agents, then draw spawn hierarchy and communication links<br>using the green (spawn) and cyan (comm) ports on each node.</div>
          </div>
        </div>
      </div>
    </div>

    <%!-- Right panel --%>
    <div class="w-[320px] shrink-0 border-l border-zinc-800 bg-zinc-900/30 flex flex-col overflow-hidden">
      <div class="flex-1 overflow-y-auto">
        <%!-- Team config --%>
        <div class="px-3 py-2.5 border-b border-zinc-800/50">
          <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Team Configuration</h4>
          <form phx-change="ws_update_team" phx-submit="ws_update_team" class="space-y-2">
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Team Name</label>
              <input type="text" class="w-full obs-input" value={@ws_team_name} name="name" phx-debounce="300" />
            </div>
            <div class="flex gap-2">
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Strategy</label>
                <select class="w-full obs-select" name="strategy">
                  <option value="one_for_one" selected={@ws_strategy == "one_for_one"}>one_for_one</option>
                  <option value="rest_for_one" selected={@ws_strategy == "rest_for_one"}>rest_for_one</option>
                  <option value="one_for_all" selected={@ws_strategy == "one_for_all"}>one_for_all</option>
                </select>
              </div>
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Default Model</label>
                <select class="w-full obs-select" name="default_model">
                  <option value="sonnet" selected={@ws_default_model == "sonnet"}>sonnet</option>
                  <option value="opus" selected={@ws_default_model == "opus"}>opus</option>
                  <option value="haiku" selected={@ws_default_model == "haiku"}>haiku</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Project / CWD</label>
              <input type="text" class="w-full obs-input font-mono" value={@ws_cwd} name="cwd" phx-debounce="300" />
            </div>
          </form>
        </div>

        <%!-- Selected agent config --%>
        <div :if={selected} class="px-3 py-2.5 border-b border-zinc-800/50">
          <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Agent Configuration</h4>
          <form phx-change="ws_update_agent" phx-submit="ws_update_agent" class="space-y-2">
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Name</label>
              <input type="text" class="w-full obs-input" value={selected.name} name="name" phx-debounce="300" />
            </div>
            <div class="flex gap-2">
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Capability</label>
                <select class="w-full obs-select" name="capability">
                  <option :for={cap <- ~w(builder scout reviewer lead coordinator)} value={cap} selected={selected.capability == cap}>{cap}</option>
                </select>
              </div>
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Model</label>
                <select class="w-full obs-select" name="model">
                  <option :for={m <- ~w(sonnet opus haiku)} value={m} selected={selected.model == m}>{m}</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Permission Mode</label>
              <select class="w-full obs-select" name="permission">
                <option :for={p <- ~w(default plan dangerously_skip)} value={p} selected={selected.permission == p}>{p}</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Persona / System Prompt</label>
              <textarea class="w-full obs-input" rows="3" name="persona" phx-debounce="500" placeholder="You are a focused backend engineer...">{selected.persona}</textarea>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">File Scope (one per line)</label>
              <textarea class="w-full obs-input font-mono" rows="2" name="file_scope" phx-debounce="500" placeholder="lib/observatory/fleet/&#10;lib/observatory_web/live/">{selected.file_scope}</textarea>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">Quality Gates (one per line)</label>
              <textarea class="w-full obs-input font-mono" rows="2" name="quality_gates" phx-debounce="500" placeholder="mix compile --warnings-as-errors">{selected.quality_gates}</textarea>
            </div>
          </form>
          <button phx-click="ws_remove_agent" class="w-full obs-btn obs-btn-danger mt-2">Remove Agent</button>
        </div>

        <%!-- Spawn hierarchy tree --%>
        <div class="px-3 py-2.5 border-b border-zinc-800/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Spawn Hierarchy</h4>
            <span class="text-[9px] text-zinc-600">who spawns who</span>
          </div>
          <%= if tree == [] do %>
            <div class="text-[10px] text-zinc-600">
              {if @ws_agents == [], do: "No agents yet", else: "Draw spawn links to build hierarchy"}
            </div>
          <% else %>
            <div class="space-y-0.5">
              <%= for {{node, depth}, _idx} <- Enum.with_index(tree) do %>
                <div class="flex items-center gap-1 group" style={"padding-left: #{depth * 16}px"}>
                  <span :if={depth > 0} class="text-[9px] text-zinc-700 font-mono w-3">&boxur;</span>
                  <span class="w-[5px] h-[5px] rounded-full shrink-0" style={"background: #{wc.cap_dot(node.capability)}"} />
                  <span class="text-[10px] text-zinc-300 flex-1">{node.name}</span>
                  <span class={"text-[7px] font-bold uppercase px-1 py-0.5 rounded #{wc.cap_badge(node.capability)}"}>{wc.cap_abbr(node.capability)}</span>
                  <%!-- Find spawn link index for removal (child nodes only) --%>
                  <% link_idx = if depth > 0, do: Enum.find_index(@ws_spawn_links, fn l -> l.to == node.id end) %>
                  <button :if={link_idx} phx-click="ws_remove_spawn_link" phx-value-index={link_idx} class="text-zinc-700 hover:text-red-400 opacity-0 group-hover:opacity-100 cursor-pointer text-[10px]" title="Remove spawn link">&times;</button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%!-- Comm rules --%>
        <div class="px-3 py-2.5 border-b border-zinc-800/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Communication Rules</h4>
            <span class="text-[9px] text-zinc-600">{length(@ws_comm_rules)} rules</span>
          </div>
          <%= if @ws_comm_rules == [] do %>
            <div class="text-[10px] text-zinc-600">No communication rules yet.</div>
          <% else %>
            <div class="space-y-1">
              <%= for {rule, idx} <- Enum.with_index(@ws_comm_rules) do %>
                <% from = wc.find_agent(@ws_agents, rule.from) %>
                <% to = wc.find_agent(@ws_agents, rule.to) %>
                <% via = if rule.via, do: wc.find_agent(@ws_agents, rule.via) %>
                <div :if={from && to} class="flex items-center gap-1.5 text-[10px]">
                  <span class={"text-[9px] px-1.5 py-0.5 rounded #{wc.comm_tag_class(rule.policy)}"}>{rule.policy}</span>
                  <span class="text-zinc-300">{from.name}</span>
                  <span class="text-zinc-600">&rarr;</span>
                  <span class="text-zinc-300">{to.name}</span>
                  <span :if={via} class="text-[9px] text-violet-400">via {via.name}</span>
                  <span class="flex-1" />
                  <button phx-click="ws_remove_comm_rule" phx-value-index={idx} class="text-zinc-600 hover:text-red-400 cursor-pointer text-[10px]">&times;</button>
                </div>
              <% end %>
            </div>
          <% end %>
          <div class="flex gap-1 mt-2 flex-wrap">
            <button phx-click="ws_add_comm_rule_manual" phx-value-policy="allow" class="obs-btn obs-btn-muted text-[9px]"><span class="text-emerald-400">+</span> allow</button>
            <button phx-click="ws_add_comm_rule_manual" phx-value-policy="deny" class="obs-btn obs-btn-muted text-[9px]"><span class="text-red-400">+</span> deny</button>
            <button phx-click="ws_add_comm_rule_manual" phx-value-policy="route" class="obs-btn obs-btn-muted text-[9px]"><span class="text-violet-400">+</span> route-via</button>
          </div>
        </div>

        <%!-- Saved Blueprints --%>
        <div class="px-3 py-2.5 border-b border-zinc-800/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Saved Blueprints</h4>
            <div class="flex gap-1">
              <button :if={@ws_blueprint_id} phx-click="ws_new_blueprint" class="obs-btn obs-btn-muted text-[9px]">New</button>
              <button :if={@ws_agents != []} phx-click="ws_save_blueprint" class="obs-btn obs-btn-muted text-[9px]">
                {if @ws_blueprint_id, do: "Update", else: "Save"}
              </button>
            </div>
          </div>
          <%= if @ws_blueprints == [] do %>
            <div class="text-[10px] text-zinc-600">No saved blueprints yet.</div>
          <% else %>
            <div class="space-y-1">
              <%= for bp <- @ws_blueprints do %>
                <div class={"flex items-center gap-1.5 text-[10px] px-2 py-1.5 rounded group #{if @ws_blueprint_id && @ws_blueprint_id == bp.id, do: "bg-cyan-500/10 border border-cyan-500/20", else: "bg-zinc-800/50 hover:bg-zinc-800"}"}>
                  <span class="text-zinc-300 truncate flex-1">{bp.name}</span>
                  <span class="text-[9px] text-zinc-600">{length(bp.agent_blueprints)} agents</span>
                  <button phx-click="ws_load_blueprint" phx-value-id={bp.id} class="text-cyan-400 hover:text-cyan-300 opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]">load</button>
                  <button phx-click="ws_delete_blueprint" phx-value-id={bp.id} class="text-red-400 hover:text-red-300 opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]" data-confirm={"Delete blueprint \"#{bp.name}\"?"}>del</button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%!-- Launch --%>
        <div :if={@ws_agents != []} class="px-3 py-2.5">
          <button phx-click="ws_launch_team" class="w-full obs-btn obs-btn-success text-xs py-2" data-confirm={"Launch team \"#{@ws_team_name}\" with #{length(@ws_agents)} agents?"}>
            Launch Team
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
