<%
  is_selected = @selected && @selected[:agent_id] == @agent[:agent_id]
  health = @agent[:health] || :unknown
  status = @agent[:status] || :unknown

  border_color =
    cond do
      is_selected -> "border-interactive/60 bg-raised/60"
      health == :critical -> "border-error/40"
      health == :warning -> "border-brand/40"
      status == :active -> "border-success/30"
      status == :idle -> "border-border-subtle"
      true -> "border-border"
    end
%>
<button
  phx-click="select_command_agent"
  phx-value-id={@agent[:agent_id] || @agent[:name]}
  class={"bg-base/50 border rounded-lg p-3 text-left hover:border-border-subtle transition cursor-pointer #{border_color}"}
>
  <div class="flex items-center gap-2 mb-2">
    <span class={[
      "w-2 h-2 rounded-full shrink-0",
      status_dot_color(status)
    ]} />
    <span class="text-sm font-medium text-high truncate">
      {@agent[:name] || short_id(@agent[:agent_id])}
    </span>
    <span :if={@agent[:model]} class="text-[10px] text-muted ml-auto">
      {short_model(@agent[:model])}
    </span>
  </div>

  <%!-- Current tool or idle --%>
  <div class="text-xs mb-1">
    <%= if @agent[:current_tool] do %>
      <% %{tool_name: tool, elapsed: elapsed} = @agent[:current_tool] %>
      <span class="text-interactive font-mono">{tool}</span>
      <span class="text-muted">{elapsed}s</span>
    <% else %>
      <span class="text-muted italic">idle</span>
    <% end %>
  </div>

  <%!-- Current task --%>
  <div :if={@agent[:current_task_id]} class="text-xs text-low truncate">
    #{@agent[:current_task_id]}
    <span :if={@agent[:current_task_subject]} class="text-muted">
      {@agent[:current_task_subject]}
    </span>
  </div>

  <%!-- Health warnings --%>
  <div :if={@agent[:health_issues] && @agent[:health_issues] != []} class="mt-1">
    <span
      :for={{type, _detail} <- Enum.take(@agent[:health_issues], 1)}
      class="text-[10px] px-1 py-0.5 rounded bg-error/15 text-error"
    >
      {format_health_issue(type)}
    </span>
  </div>
</button>
