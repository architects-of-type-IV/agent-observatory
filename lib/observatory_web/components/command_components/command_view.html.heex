<%
  agents = collect_agents(@teams, @events, @now)
  stats = fleet_stats(agents)
  pipeline = @swarm_state.pipeline
  health = @swarm_state.health
  stale = @swarm_state.stale_tasks
  alerts = build_alerts(health.issues, stale)
  errors = @errors
  messages = assigns[:messages] || []
  protocol_stats = assigns[:protocol_stats] || %{}
  active_tasks = assigns[:active_tasks] || []
  # Aggregate counts for fleet bar
  error_count = length(errors)
  msg_count = length(messages)
  task_count = length(active_tasks)
  task_done = Enum.count(active_tasks, fn t -> t[:status] == "completed" end)
  tool_count = agents |> Enum.map(fn a -> if is_integer(a.tool_count), do: a.tool_count, else: 0 end) |> Enum.sum()

  # Recent errors (top 3)
  recent_errors = Enum.take(errors, 3)
  # Recent messages (top 5)
  recent_msgs = Enum.take(messages, 5)

  # Protocol summary (stats are nested maps, not plain ints)
  proto_traces = protocol_stats[:traces] || 0
  proto_mailbox = get_in(protocol_stats, [:mailbox, :total_pending]) || 0
  proto_cmdq = get_in(protocol_stats, [:command_queue, :total_pending]) || 0
%>
<div class="p-4 flex flex-col gap-3">
  <%!-- Mesh Topology --%>
  <div id="fleet-topology-hook" phx-hook="TopologyMap" phx-update="ignore" data-event="fleet_topology_update" class="bg-zinc-900/30 border border-zinc-800 rounded-lg p-4 min-h-[280px] relative">
    <h3 class="topo-title text-[10px] font-semibold text-zinc-600 uppercase tracking-wider mb-2">Topology</h3>
  </div>

  <%!-- Fleet Status Bar -- all dimensions at a glance --%>
  <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-2">
    <div class="flex items-center gap-4 flex-wrap">
      <%!-- Nodes --%>
      <div class="flex items-center gap-2">
        <span class="text-xl font-bold text-zinc-200">{stats.total}</span>
        <div class="flex items-center gap-1.5 text-[10px] font-mono">
          <span :if={stats.active > 0} class="text-emerald-400">{stats.active}a</span>
          <span :if={stats.idle > 0} class="text-zinc-400">{stats.idle}i</span>
          <span :if={stats.ended > 0} class="text-zinc-600">{stats.ended}e</span>
        </div>
      </div>

      <span class="w-px h-5 bg-zinc-800" />

      <%!-- Errors --%>
      <div class={["flex items-center gap-1.5 text-xs", if(error_count > 0, do: "text-red-400", else: "text-zinc-600")]}>
        <span class={["w-1.5 h-1.5 rounded-full", if(error_count > 0, do: "bg-red-400", else: "bg-zinc-700")]} />
        <span class="font-mono">{error_count}</span>
        <span class="text-[10px]">errors</span>
      </div>

      <%!-- Messages --%>
      <div class="flex items-center gap-1.5 text-xs text-zinc-500">
        <span class="font-mono">{msg_count}</span>
        <span class="text-[10px]">msgs</span>
      </div>

      <%!-- Tools --%>
      <div class="flex items-center gap-1.5 text-xs text-zinc-500">
        <span class="font-mono">{tool_count}</span>
        <span class="text-[10px]">tools</span>
      </div>

      <span class="flex-1" />

      <%!-- Tasks pipeline --%>
      <div :if={task_count > 0} class="flex items-center gap-2">
        <div class="w-20 h-1.5 bg-zinc-800 rounded-full overflow-hidden">
          <% pct = if task_count > 0, do: round(task_done / task_count * 100), else: 0 %>
          <div class="h-full bg-emerald-500 rounded-full" style={"width: #{pct}%"} />
        </div>
        <span class="text-[10px] font-mono text-zinc-500">{task_done}/{task_count}</span>
      </div>

      <%!-- Swarm pipeline --%>
      <div :if={pipeline.total > 0 && pipeline.total != task_count} class="flex items-center gap-2">
        <% ppct = progress_pct(pipeline) %>
        <div class="w-16 h-1.5 bg-zinc-800 rounded-full overflow-hidden">
          <div class="h-full bg-cyan-500 rounded-full" style={"width: #{ppct}%"} />
        </div>
        <span class="text-[10px] font-mono text-zinc-500">{pipeline.completed}/{pipeline.total}</span>
      </div>

      <%!-- Health --%>
      <div class={[
        "flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-medium",
        if(health.healthy && error_count == 0,
          do: "bg-emerald-500/15 text-emerald-400",
          else: "bg-red-500/15 text-red-400"
        )
      ]}>
        <span class={[
          "w-1.5 h-1.5 rounded-full",
          if(health.healthy && error_count == 0, do: "bg-emerald-400", else: "bg-red-400 animate-pulse")
        ]} />
        {cond do
          error_count > 0 && !health.healthy -> "#{error_count + length(health.issues)}!"
          error_count > 0 -> "#{error_count}!"
          !health.healthy -> "#{length(health.issues)}!"
          true -> "OK"
        end}
      </div>

      <%!-- Protocols --%>
      <div :if={proto_traces + proto_mailbox + proto_cmdq > 0} class="flex items-center gap-2 text-[10px] font-mono text-zinc-600">
        <span :if={proto_traces > 0}>T:{proto_traces}</span>
        <span :if={proto_mailbox > 0}>M:{proto_mailbox}</span>
        <span :if={proto_cmdq > 0}>Q:{proto_cmdq}</span>
      </div>
    </div>
  </div>

  <%!-- Activity + Detail --%>
  <div class="flex gap-4">
    <div class="flex-1 min-w-0 space-y-3">
      <%!-- Errors --%>
      <div :if={recent_errors != []} class="rounded-lg border border-red-900/30 bg-red-950/10">
        <div class="flex items-center gap-2 px-3 py-1.5 border-b border-red-900/20">
          <span class="text-[10px] text-red-500 uppercase tracking-wider">errors</span>
          <span class="text-xs font-mono text-red-400">{error_count}</span>
        </div>
        <div class="divide-y divide-zinc-800/30">
          <div :for={err <- recent_errors} class="px-3 py-1.5 text-xs text-red-300/80 truncate">
            <span class="text-red-500 font-mono mr-1">{err[:tool_name] || err[:hook_event_type] || "error"}</span>
            <span class="text-zinc-500">{if err[:cwd], do: Path.basename(err[:cwd]), else: short_id(err[:session_id])}</span>
          </div>
        </div>
      </div>

      <%!-- Recent Messages --%>
      <div :if={recent_msgs != []} class="rounded-lg border border-zinc-800 bg-zinc-900/30">
        <div class="flex items-center gap-2 px-3 py-1.5 border-b border-zinc-800/50">
          <span class="text-[10px] text-zinc-500 uppercase tracking-wider">messages</span>
          <span class="text-xs font-mono text-zinc-500">{msg_count}</span>
        </div>
        <div class="divide-y divide-zinc-800/30">
          <div :for={msg <- recent_msgs} class="px-3 py-1.5 flex items-center gap-2 text-xs">
            <span class="text-cyan-500 font-mono truncate w-16">{msg[:from] || "?"}</span>
            <span class="text-zinc-600">-></span>
            <span class="text-zinc-400 font-mono truncate w-16">{msg[:to] || "?"}</span>
            <span class="text-zinc-500 truncate flex-1">{String.slice(to_string(msg[:content] || msg[:body] || ""), 0, 60)}</span>
          </div>
        </div>
      </div>

      <%!-- Alerts --%>
      <div :if={alerts != []} class="space-y-1">
        <div
          :for={alert <- Enum.take(alerts, 8)}
          class="flex items-center gap-2 px-3 py-1.5 rounded bg-zinc-900/50 border border-zinc-800"
        >
          <span class={["w-1.5 h-1.5 rounded-full shrink-0", severity_color(alert.severity)]} />
          <span class={"text-xs flex-1 truncate #{severity_text_color(alert.severity)}"}>{alert.message}</span>
          <button
            :if={alert.action}
            phx-click={alert.action}
            phx-value-task_id={alert.target_id}
            class="text-[10px] px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-400 hover:text-zinc-200"
          >
            {alert.action_label}
          </button>
        </div>
      </div>
    </div>

    <%!-- Right: Detail Panel --%>
    <div :if={@selected_command_agent || @selected_command_task} class="w-80 shrink-0">
      <.selected_detail
        agent={@selected_command_agent}
        task={@selected_command_task}
        now={@now}
      />
    </div>
  </div>
</div>
