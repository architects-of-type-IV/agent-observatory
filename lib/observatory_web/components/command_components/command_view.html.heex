<%
  agents = collect_agents(@teams, @events, @now)
  tmux_agents = collect_tmux_agents(assigns[:tmux_sessions] || [], agents)
  all_agents = agents ++ tmux_agents
  total_agents = length(all_agents)
  agent_index = Map.new(all_agents, fn a -> {a.agent_id, a} end)

  # HITL paused sessions
  hitl_paused = try do
    Observatory.Gateway.HITLRelay.paused_sessions() |> MapSet.new()
  rescue
    _ -> MapSet.new()
  end

  # Name map for comms display
  names = FH.name_map(@teams, all_agents)

  # Mailbox messages for comms timeline
  mailbox_messages = Observatory.Mailbox.all_messages(50)
  comms_filter = assigns[:comms_team_filter]
  filtered_messages = FH.filter_by_team(mailbox_messages, comms_filter, @teams)

  # Standalone agents (not in any team)
  team_ids = @teams |> Enum.flat_map(& &1.members) |> Enum.map(& &1[:agent_id]) |> MapSet.new()
  standalone = Enum.reject(all_agents, fn a -> MapSet.member?(team_ids, a.agent_id) end)

  # Group teams by project
  project_groups = FH.group_teams_by_project(@teams)

  collapsed = assigns[:collapsed_fleet_teams] || MapSet.new()
  selected = @selected_command_agent
%>
<div class="flex h-full">
  <%!-- Left: Fleet Tree (360px) --%>
  <div class="w-[360px] shrink-0 border-r border-zinc-800 bg-zinc-900/30 flex flex-col overflow-hidden">
    <div class="px-2.5 py-1.5 border-b border-zinc-800 flex items-center justify-between shrink-0">
      <h3 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider">Fleet</h3>
      <span class="text-[9px] text-zinc-600">{total_agents} agents</span>
    </div>
    <div class="flex-1 overflow-y-auto">
      <%!-- Teams grouped by project --%>
      <%= for {project, teams} <- project_groups do %>
        <div class="border-b border-zinc-800/50">
          <%!-- Project header --%>
          <div class="px-2.5 pt-2 pb-0.5 flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-sm bg-indigo-500/40 shrink-0" />
            <span class="text-[9px] font-semibold text-zinc-500 uppercase tracking-wider">{project}</span>
          </div>

          <%!-- Teams under this project --%>
          <%= for team <- teams do %>
            <% is_collapsed = MapSet.member?(collapsed, team.name) %>
            <div>
              <div
                class="flex items-center gap-2 pl-5 pr-2.5 py-1 cursor-pointer hover:bg-zinc-800/30 transition"
                phx-click="toggle_fleet_team"
                phx-value-name={team.name}
              >
                <span class={"text-[9px] text-zinc-600 inline-block transition-transform #{if is_collapsed, do: "", else: "rotate-90"}"}>&#x25B8;</span>
                <span class="text-[11px] font-semibold text-zinc-300">{team.name}</span>
                <span class="text-[9px] text-zinc-600 font-mono">{length(team.members)}</span>
                <span class="flex-1" />
                <button
                  phx-click="set_comms_filter"
                  phx-value-team={team.name}
                  class={"text-[9px] px-1.5 py-0.5 rounded cursor-pointer #{if comms_filter == team.name, do: "bg-indigo-500/15 text-indigo-400", else: "text-zinc-600 hover:text-zinc-400"}"}
                >
                  comms
                </button>
              </div>

              <%= unless is_collapsed do %>
                <div class="pb-1">
                  <% sorted = FH.sort_members(team.members, agent_index) %>
                  <% member_count = length(sorted) %>
                  <%= for {{member, agent_data, d}, idx} <- Enum.with_index(sorted) do %>
                    <% indent = 20 + d * 32 %>
                    <% mid = member[:agent_id] %>
                    <% is_last = idx == member_count - 1 %>
                    <% is_selected = selected && (selected[:agent_id] == mid || selected[:name] == (member[:name] || member[:agent_type])) %>
                    <% role = FH.classify_role(member[:name] || member[:agent_type]) %>
                    <% connector = if is_last, do: "&#x2514;", else: "&#x251C;" %>
                    <div
                      class={"flex items-center gap-1.5 py-0.5 cursor-pointer transition border-l-2 #{if is_selected, do: "bg-indigo-500/10 border-indigo-500", else: "border-transparent hover:bg-zinc-800/20"}"}
                      style={"padding-left: #{indent}px; padding-right: 10px;"}
                      phx-click="select_command_agent"
                      phx-value-id={mid}
                    >
                      <span class="text-[9px] text-zinc-700 w-2.5 shrink-0 text-center"><%= raw(connector) %></span>
                      <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{status_dot_color(agent_data[:status] || member[:status] || :idle)}"} />
                      <span class="text-[11px] text-zinc-300 truncate flex-1">{member[:name] || member[:agent_type] || "?"}</span>
                      <span :if={role != :member} class={"text-[8px] font-bold uppercase px-1 py-0.5 rounded border #{FH.badge_class(role)}"}>{FH.abbrev(role)}</span>
                      <span :if={mid && MapSet.member?(hitl_paused, mid)} class="text-[8px] font-bold uppercase px-1 py-0.5 rounded bg-amber-500/20 text-amber-400 border border-amber-500/30">PAUSED</span>
                      <span class="text-[9px] text-indigo-400">{short_model(agent_data[:model] || member[:model])}</span>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%!-- Standalone agents --%>
      <div :if={standalone != []} class="border-b border-zinc-800/50">
        <div class="px-2.5 py-1.5 text-[10px] text-zinc-600 uppercase tracking-wider">Standalone</div>
        <%= for agent <- standalone do %>
          <% is_selected = selected && selected[:agent_id] == agent.agent_id %>
          <div
            class={"flex items-center gap-1.5 px-5 py-1 cursor-pointer transition border-l-2 #{if is_selected, do: "bg-indigo-500/10 border-indigo-500", else: "border-transparent hover:bg-zinc-800/20"}"}
            phx-click="select_command_agent"
            phx-value-id={agent.agent_id}
          >
            <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{status_dot_color(agent.status)}"} />
            <span class="text-[11px] text-zinc-300 truncate flex-1">{agent.name}</span>
            <span :if={MapSet.member?(hitl_paused, agent.agent_id)} class="text-[8px] font-bold uppercase px-1 py-0.5 rounded bg-amber-500/20 text-amber-400 border border-amber-500/30">PAUSED</span>
            <span :if={agent[:tmux_session]} class="text-[9px] text-amber-500 font-mono shrink-0">tmux</span>
            <span class="text-[9px] text-indigo-400">{short_model(agent.model)}</span>
          </div>
        <% end %>
      </div>

      <div :if={@teams == [] && standalone == []} class="px-3 py-8 text-center">
        <div class="text-[10px] text-zinc-600 uppercase tracking-wider mb-1">No agents detected</div>
        <div class="text-[10px] text-zinc-700">Start a Claude session to see it here.</div>
      </div>
    </div>
  </div>

  <%!-- Center: Comms Timeline --%>
  <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
    <%!-- Command bar --%>
    <div class="px-3 py-1.5 border-b border-zinc-800 bg-zinc-900/30 shrink-0">
      <div class="flex gap-1.5 flex-wrap">
        <form phx-submit="send_targeted_message" id="command-msg-form" class="flex gap-1 flex-1 min-w-0">
          <div id="target-select-stable" phx-update="ignore">
            <select name="target" class="obs-select shrink-0">
              <option value="">Target...</option>
              <optgroup label="Broadcast">
                <option value="all">All Agents</option>
                <%= for team <- @teams do %>
                  <option value={"team:#{team.name}"}>Team: {team.name}</option>
                <% end %>
              </optgroup>
              <optgroup label="Agents">
                <%= for agent <- all_agents do %>
                  <option value={agent.agent_id}>{agent.name}{if agent[:team_name], do: " (#{agent.team_name})", else: ""}</option>
                <% end %>
              </optgroup>
            </select>
          </div>
          <div id="cmd-input-stable" phx-update="ignore" phx-hook="ClearFormOnSubmit" class="flex-1 min-w-0">
            <input type="text" name="content" placeholder="Message..." class="w-full obs-input" />
          </div>
          <button type="submit" class="obs-btn obs-btn-primary shrink-0">Send</button>
        </form>
        <form phx-submit="launch_session" class="flex gap-1 shrink-0">
          <div id="project-select-stable" phx-update="ignore">
            <select name="cwd" class="obs-select">
              <option value="">Project...</option>
              <%= for {key, path} <- @swarm_state.watched_projects do %>
                <option value={path}>{key}</option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="obs-btn obs-btn-success shrink-0">Launch</button>
        </form>
      </div>
    </div>

    <%!-- Tab bar: Comms / Feed --%>
    <% active_tab = assigns[:activity_tab] || :comms %>
    <div class="px-3 py-1 border-b border-zinc-800 flex items-center justify-between shrink-0">
      <div class="flex gap-2">
        <span
          phx-click="set_sub_tab"
          phx-value-screen="activity"
          phx-value-tab="comms"
          class={"text-[10px] font-semibold uppercase tracking-wider cursor-pointer transition #{if active_tab in [:comms, :feed] && active_tab == :comms, do: "text-indigo-400", else: "text-zinc-600 hover:text-zinc-400"}"}
        >Comms</span>
        <span
          phx-click="set_sub_tab"
          phx-value-screen="activity"
          phx-value-tab="feed"
          class={"text-[10px] font-semibold uppercase tracking-wider cursor-pointer transition #{if active_tab == :feed, do: "text-indigo-400", else: "text-zinc-600 hover:text-zinc-400"}"}
        >Feed</span>
      </div>
      <div :if={active_tab != :feed} class="flex gap-1">
        <span
          phx-click="set_comms_filter"
          phx-value-team=""
          class={"text-[9px] px-1.5 py-0.5 rounded cursor-pointer transition #{if !comms_filter, do: "bg-indigo-500/15 text-indigo-400", else: "text-zinc-500 hover:text-zinc-300"}"}
        >All</span>
        <%= for team <- @teams do %>
          <span
            phx-click="set_comms_filter"
            phx-value-team={team.name}
            class={"text-[9px] px-1.5 py-0.5 rounded cursor-pointer transition #{if comms_filter == team.name, do: "bg-indigo-500/15 text-indigo-400", else: "text-zinc-500 hover:text-zinc-300"}"}
          >{team.name}</span>
        <% end %>
        <span class="text-[9px] text-zinc-600 ml-1">{length(filtered_messages)} msgs</span>
      </div>
      <div :if={active_tab == :feed} class="flex gap-1">
        <button phx-click="expand_all" class="text-[9px] px-1.5 py-0.5 rounded text-zinc-500 hover:text-zinc-300 cursor-pointer transition">Expand</button>
        <button phx-click="collapse_all" class="text-[9px] px-1.5 py-0.5 rounded text-zinc-500 hover:text-zinc-300 cursor-pointer transition">Collapse</button>
        <span class="text-[9px] text-zinc-600 ml-1">{length(@feed_groups)} sessions</span>
      </div>
    </div>

    <%!-- Comms: Message timeline --%>
    <div :if={active_tab != :feed} class="flex-1 overflow-y-auto">
      <%= if filtered_messages == [] do %>
        <div class="flex-1 flex items-center justify-center p-6">
          <div class="text-center max-w-xs">
            <p class="text-[11px] text-zinc-500 mb-2">No messages yet</p>
            <p class="text-[10px] text-zinc-600 leading-relaxed">
              Send a message from the command bar above, or use the MCP API.
            </p>
          </div>
        </div>
      <% else %>
        <div class="divide-y divide-zinc-800/30">
          <%= for msg <- filtered_messages do %>
            <% from_label = FH.resolve_label(msg.from, names) %>
            <% to_label = FH.resolve_label(msg.to, names) %>
            <% is_operator = msg.from == "operator" || msg.from == "dashboard" %>
            <div class={"px-4 py-2.5 hover:bg-zinc-800/20 transition #{if is_operator, do: "border-l-2 border-amber-500/30", else: ""}"}>
              <div class="flex items-center gap-2 mb-1">
                <span class={"text-[10px] font-semibold #{if is_operator, do: "text-amber-400", else: "text-zinc-300"}"}>{from_label}</span>
                <svg class="w-3 h-3 text-zinc-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
                <span class={"text-[10px] font-semibold #{if msg.to == "operator", do: "text-amber-400", else: "text-zinc-300"}"}>{to_label}</span>
                <span class="flex-1" />
                <span class={"text-[9px] px-1.5 py-0.5 rounded #{if msg.read, do: "text-emerald-500", else: "text-amber-400 bg-amber-500/10"}"}>{if msg.read, do: "read", else: "unread"}</span>
                <span class="text-[9px] text-zinc-600 font-mono tabular-nums">{FH.format_timestamp(msg.timestamp)}</span>
              </div>
              <p class="text-[11px] text-zinc-400 leading-relaxed pl-0.5">{msg.content}</p>
              <div class="flex items-center gap-3 mt-1 pl-0.5">
                <span class="flex items-center gap-1">
                  <span class="w-1 h-1 rounded-full bg-emerald-400" />
                  <span class="text-[9px] text-zinc-600">mailbox</span>
                </span>
                <span :if={msg.type && msg.type != :text} class="text-[9px] text-zinc-600">{msg.type}</span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%!-- Feed: Turn-based live activity --%>
    <div :if={active_tab == :feed} class="flex-1 overflow-y-auto p-2">
      <.feed_view
        feed_groups={@feed_groups}
        visible_events={@visible_events}
        selected_event={@selected_event}
        event_notes={@event_notes}
        expanded_sessions={@expanded_sessions}
        now={@now}
      />
    </div>
  </div>

  <%!-- Right: Detail Panel (400px, conditional) --%>
  <div :if={selected} class="w-[400px] shrink-0 border-l border-zinc-800 bg-zinc-900/30 flex flex-col overflow-hidden">
    <%
      sel_id = selected[:agent_id] || selected[:name]
      sel_agent = Map.get(agent_index, sel_id, selected)
      sel_name = selected[:name] || sel_agent[:name] || sel_id
      sel_team = Enum.find(@teams, fn t -> Enum.any?(t.members, fn m -> m[:agent_id] == sel_id end) end)
      sel_member = if sel_team, do: Enum.find(sel_team.members, fn m -> m[:agent_id] == sel_id end)
      sel_role = if sel_member, do: FH.classify_role(sel_member[:name] || sel_member[:agent_type])

      # Chain of command
      {reports_to, manages} = if sel_team do
        sorted = FH.sort_members(sel_team.members, agent_index)
        FH.chain_of_command(sel_member, sorted)
      else
        {nil, []}
      end

      # Tmux session for this agent
      sel_tmux = sel_agent[:tmux_session] || (sel_member && sel_member[:tmux_session])

      # Recent messages
      agent_msgs = Enum.filter(mailbox_messages, fn m -> m.from == sel_id || m.to == sel_id end) |> Enum.take(4)
    %>
    <div class="px-3 py-1.5 border-b border-zinc-800 flex items-center justify-between shrink-0">
      <h3 class="text-[11px] font-semibold text-zinc-300">{sel_name}</h3>
      <button phx-click="clear_command_selection" class="text-[11px] text-zinc-600 hover:text-zinc-300 cursor-pointer">x</button>
    </div>
    <div class="flex-1 overflow-y-auto">
      <%!-- Info --%>
      <div class="px-3 py-2.5 border-b border-zinc-800/50">
        <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Info</h4>
        <dl class="space-y-1 text-[11px]">
          <div class="flex justify-between">
            <dt class="text-zinc-500">Status</dt>
            <dd class={status_text_color(sel_agent[:status] || :unknown)}>
              {sel_agent[:status] || :unknown}
              <span :if={MapSet.member?(hitl_paused, sel_id)} class="text-amber-400 ml-1">(HITL paused)</span>
            </dd>
          </div>
          <div :if={sel_agent[:model] || (sel_member && sel_member[:model])} class="flex justify-between">
            <dt class="text-zinc-500">Model</dt>
            <dd class="text-indigo-400">{sel_agent[:model] || sel_member[:model]}</dd>
          </div>
          <div :if={sel_role && sel_role != :member} class="flex justify-between">
            <dt class="text-zinc-500">Role</dt>
            <dd class="text-zinc-300">{sel_role}</dd>
          </div>
          <div :if={sel_team} class="flex justify-between">
            <dt class="text-zinc-500">Team</dt>
            <dd class="text-zinc-300">{sel_team.name}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-zinc-500">Events</dt>
            <dd class="text-zinc-300">{sel_agent[:event_count] || 0}</dd>
          </div>
          <div :if={sel_agent[:current_tool]} class="flex justify-between">
            <dt class="text-zinc-500">Current tool</dt>
            <dd class="text-cyan-400">{sel_agent.current_tool.tool_name} ({sel_agent.current_tool.elapsed}s)</dd>
          </div>
          <div :if={sel_agent[:cwd]} class="flex justify-between">
            <dt class="text-zinc-500">cwd</dt>
            <dd class="text-zinc-300 font-mono truncate max-w-[200px]" title={sel_agent[:cwd]}>{Path.basename(sel_agent[:cwd])}</dd>
          </div>
        </dl>
      </div>

      <%!-- Chain of Command --%>
      <div :if={reports_to || manages != []} class="px-3 py-2.5 border-b border-zinc-800/50">
        <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Chain of Command</h4>
        <div :if={reports_to} class="text-[10px] text-zinc-500 mb-2">
          Reports to:
          <span
            class="text-zinc-300 cursor-pointer hover:text-indigo-400 transition"
            phx-click="select_command_agent"
            phx-value-id={reports_to[:agent_id]}
          >{reports_to[:name] || reports_to[:agent_type]}</span>
        </div>
        <div :if={manages != []} class="text-[10px] text-zinc-500 mb-1">Manages:</div>
        <div :for={sub <- manages} class="flex items-center gap-1.5 pl-2 mb-1">
          <span class="text-[9px] text-zinc-700">&#x251C;</span>
          <span class={"w-1.5 h-1.5 rounded-full #{status_dot_color(Map.get(agent_index, sub[:agent_id], %{})[:status] || :idle)}"} />
          <span
            class="text-[10px] text-zinc-300 cursor-pointer hover:text-indigo-400 transition"
            phx-click="select_command_agent"
            phx-value-id={sub[:agent_id]}
          >{sub[:name] || sub[:agent_type]}</span>
        </div>
      </div>

      <%!-- Recent Messages --%>
      <div :if={agent_msgs != []} class="px-3 py-2.5 border-b border-zinc-800/50">
        <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Recent Messages</h4>
        <div :for={msg <- agent_msgs} class="mb-2.5">
          <div class="flex items-center gap-1.5 mb-0.5">
            <% is_sent = msg.from == sel_id %>
            <span class={"text-[9px] #{if is_sent, do: "text-indigo-400", else: "text-emerald-400"}"}>{if is_sent, do: "sent", else: "recv"}</span>
            <span class="text-[9px] text-zinc-500">{if is_sent, do: "to", else: "from"}</span>
            <span class="text-[9px] text-zinc-300">{FH.resolve_label(if(is_sent, do: msg.to, else: msg.from), names)}</span>
            <span class="flex-1" />
            <span class="text-[9px] text-zinc-600 font-mono">{FH.format_timestamp(msg.timestamp)}</span>
          </div>
          <p class="text-[10px] text-zinc-400 leading-relaxed pl-0.5 line-clamp-2">{msg.content}</p>
        </div>
      </div>

      <%!-- Actions --%>
      <%
        is_hitl_paused = MapSet.member?(hitl_paused, sel_id)
        hitl_buffer = if is_hitl_paused do
          try do
            Observatory.Gateway.HITLRelay.buffered_messages(sel_id)
          rescue
            _ -> []
          end
        else
          []
        end
      %>
      <div class="px-3 py-2.5 border-b border-zinc-800/50">
        <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Actions</h4>
        <div class="flex flex-wrap gap-1.5">
          <button :if={sel_tmux} phx-click="connect_tmux" phx-value-session={sel_tmux} class="obs-btn bg-amber-600/15 text-amber-400 hover:bg-amber-600/25">Tmux</button>
          <button phx-click="open_agent_slideout" phx-value-session_id={sel_id} class="obs-btn obs-btn-primary">Focus</button>
          <button :if={!is_hitl_paused} phx-click="pause_agent" phx-value-session_id={sel_id} class="obs-btn obs-btn-muted">Pause</button>
          <button :if={is_hitl_paused} phx-click="resume_agent" phx-value-session_id={sel_id} class="obs-btn obs-btn-muted">Resume</button>
          <button phx-click="shutdown_agent" phx-value-session_id={sel_id} class="obs-btn obs-btn-muted text-red-400" data-confirm="Shut down this agent?">Shutdown</button>
        </div>
      </div>

      <%!-- HITL Buffer (when paused) --%>
      <div :if={is_hitl_paused} class="px-3 py-2.5 border-b border-zinc-800/50">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-[10px] font-semibold text-amber-400 uppercase tracking-wider">HITL Gate Open</h4>
          <span class="text-[9px] text-zinc-500 font-mono">{length(hitl_buffer)} buffered</span>
        </div>
        <div class="bg-amber-500/5 border border-amber-500/20 rounded p-2 mb-2">
          <p class="text-[10px] text-amber-300/80 mb-2">Messages to this agent are being buffered. Review and approve or reject.</p>
          <%= if hitl_buffer == [] do %>
            <p class="text-[10px] text-zinc-600 italic">No messages buffered yet.</p>
          <% else %>
            <div class="space-y-1.5 max-h-32 overflow-y-auto mb-2">
              <%= for {msg, idx} <- Enum.with_index(hitl_buffer) do %>
                <div class="flex items-start gap-1.5 text-[10px]">
                  <span class="text-zinc-600 font-mono shrink-0">#{idx + 1}</span>
                  <div class="min-w-0">
                    <span :if={msg[:agent_id]} class="text-zinc-500">from: {msg.agent_id |> to_string() |> String.slice(0, 8)}</span>
                    <p class="text-zinc-400 truncate">{inspect(msg[:payload] || msg[:content] || msg, limit: 120)}</p>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
          <div class="flex gap-1.5 mt-2">
            <button
              phx-click="hitl_approve"
              phx-value-session_id={sel_id}
              class="obs-btn bg-emerald-600/15 text-emerald-400 hover:bg-emerald-600/25 flex-1"
            >Approve & Flush</button>
            <button
              phx-click="hitl_reject"
              phx-value-session_id={sel_id}
              class="obs-btn bg-red-600/15 text-red-400 hover:bg-red-600/25 flex-1"
              data-confirm="Discard all buffered messages?"
            >Reject</button>
          </div>
        </div>
      </div>

      <%!-- Direct Message --%>
      <div class="px-3 py-2.5">
        <h4 class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider mb-2">Send Message</h4>
        <div class="text-[10px] text-zinc-600 mb-1">To: <span class="text-zinc-400 font-mono">{sel_name}</span></div>
        <div phx-update="ignore" id={"fleet-msg-#{sel_id}"} phx-hook="ClearFormOnSubmit">
          <form phx-submit="send_command_message" class="flex gap-1.5">
            <input type="hidden" name="to" value={sel_id} />
            <input type="text" name="content" placeholder={"Message #{sel_name}..."} class="flex-1 obs-input" />
            <button type="submit" class="obs-btn obs-btn-primary">Send</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
