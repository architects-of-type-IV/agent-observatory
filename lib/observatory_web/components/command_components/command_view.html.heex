<%
  agents = collect_agents(@teams, @events, @now)
  tmux_agents = collect_tmux_agents(assigns[:tmux_sessions] || [], agents)
  agents = agents ++ tmux_agents
  health = @swarm_state.health
  stale = @swarm_state.stale_tasks
  alerts = build_alerts(health.issues, stale)
  errors = @errors
  error_count = length(errors)
  recent_errors = Enum.take(errors, 3)

  # Group agents by tmux session for cluster view
  tmux_groups = agents |> Enum.filter(& &1[:tmux_session]) |> Enum.group_by(& &1.tmux_session)
  ungrouped = Enum.reject(agents, & &1[:tmux_session])
%>
<div class="flex flex-col h-full">
  <%!-- Header bar: command bar + launch --%>
  <div class="px-3 py-1.5 border-b border-zinc-800 bg-zinc-900/30 shrink-0">
    <div class="flex gap-1.5 flex-wrap">
      <form phx-submit="send_targeted_message" id="command-msg-form" phx-hook="ClearFormOnSubmit" class="flex gap-1 flex-1 min-w-0">
        <.stable_select id="select-target" name="target" class="obs-select shrink-0">
          <option value="">Target...</option>
          <optgroup label="Broadcast">
            <option value="all">All Agents</option>
            <%= for team <- @teams do %>
              <option value={"team:#{team.name}"}>Team: {team.name}</option>
            <% end %>
          </optgroup>
          <optgroup label="Agents">
            <%= for agent <- agents do %>
              <option value={"agent:#{agent.agent_id}"}>{agent.name}{if agent[:team_name], do: " (#{agent.team_name})", else: ""}</option>
            <% end %>
          </optgroup>
        </.stable_select>
        <input type="text" name="content" placeholder="Message..." class="flex-1 obs-input min-w-0" />
        <button type="submit" class="obs-btn obs-btn-primary shrink-0">Send</button>
      </form>
      <form phx-submit="launch_session" class="flex gap-1 shrink-0">
        <.stable_select id="select-cwd" name="cwd">
          <option value="">Project...</option>
          <%= for {key, path} <- @swarm_state.watched_projects do %>
            <option value={path}>{key}</option>
          <% end %>
        </.stable_select>
        <button type="submit" class="obs-btn obs-btn-success shrink-0">Launch</button>
      </form>
    </div>
  </div>

  <%!-- Alerts strip --%>
  <div :if={recent_errors != [] || alerts != []} class="px-3 py-1 border-b border-zinc-800/50 bg-zinc-950/30 shrink-0 space-y-0.5">
    <div :if={recent_errors != []} class="flex items-center gap-2">
      <span class="text-[10px] text-red-500 uppercase tracking-wider shrink-0">errors</span>
      <span class="text-[10px] font-mono text-red-400 shrink-0">{error_count}</span>
      <div class="flex gap-3 overflow-hidden flex-1">
        <span :for={err <- recent_errors} class="text-[10px] text-red-300/80 truncate">
          <span class="text-red-500 font-mono mr-1">{Map.get(err, :tool_name) || Map.get(err, :hook_event_type) || "error"}</span>
          <span class="text-zinc-500">{if Map.get(err, :cwd), do: Path.basename(err.cwd), else: short_id(Map.get(err, :session_id))}</span>
        </span>
      </div>
    </div>
    <div :for={alert <- Enum.take(alerts, 3)} class="flex items-center gap-2">
      <span class={["w-1.5 h-1.5 rounded-full shrink-0", severity_color(alert.severity)]} />
      <span class={"text-[10px] flex-1 truncate #{severity_text_color(alert.severity)}"}>{alert.message}</span>
      <button
        :if={alert.action}
        phx-click={alert.action}
        phx-value-task_id={alert.target_id}
        class="text-[10px] px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-400 hover:text-zinc-200"
      >
        {alert.action_label}
      </button>
    </div>
  </div>

  <%!-- Main: Left sidebar (agents) + Right content (feed) --%>
  <div class="flex flex-1 min-h-0">
    <%!-- Left sidebar: Agent list --%>
    <div class="w-[280px] shrink-0 border-r border-zinc-800 bg-zinc-900/30 overflow-y-auto">
      <div :if={agents != []} class="divide-y divide-zinc-800/30">
        <%!-- Tmux-grouped agents --%>
        <div :for={{tmux_name, group_agents} <- tmux_groups}>
          <div class="flex items-center gap-2 px-3 py-1.5 bg-zinc-900/50">
            <span class="text-[10px] text-amber-500 font-mono">{tmux_name}</span>
            <span class="text-[10px] text-zinc-600">{length(group_agents)}</span>
            <span class="flex-1" />
            <button
              phx-click="connect_tmux"
              phx-value-session={tmux_name}
              class="text-[10px] px-1.5 py-0.5 rounded bg-amber-600/20 text-amber-400 hover:bg-amber-600/30"
            >
              Connect
            </button>
          </div>
          <.agent_card :for={agent <- group_agents} agent={agent} />
        </div>

        <%!-- Ungrouped agents --%>
        <.agent_card :for={agent <- ungrouped} agent={agent} />
      </div>

      <div :if={agents == []} class="px-3 py-8 text-center">
        <div class="text-[10px] text-zinc-600 uppercase tracking-wider mb-1">No agents detected</div>
        <div class="text-[10px] text-zinc-700">Start a Claude session to see it here.</div>
      </div>
    </div>

    <%!-- Right content: Live Feed --%>
    <div class="flex-1 min-w-0 overflow-y-auto p-3">
      <div class="text-[10px] text-zinc-600 uppercase tracking-wider mb-2">Live Feed</div>
      <ObservatoryWeb.Components.FeedComponents.feed_view
        feed_groups={@feed_groups}
        visible_events={@visible_events}
        selected_event={@selected_event}
        event_notes={@event_notes}
        expanded_sessions={@expanded_sessions}
        now={@now}
      />
    </div>
  </div>
</div>
