<%
  tasks = @swarm_state.tasks
  pipeline = @swarm_state.pipeline
  active_project = @swarm_state.active_project
  projects = @swarm_state.watched_projects

  # Group tasks by status for kanban columns
  kanban = %{
    "blocked" => Enum.filter(tasks, &(&1.status == "blocked")),
    "pending" => Enum.filter(tasks, &(&1.status == "pending")),
    "in_progress" => Enum.filter(tasks, &(&1.status == "in_progress")),
    "completed" => Enum.filter(tasks, &(&1.status == "completed")),
    "failed" => Enum.filter(tasks, &(&1.status == "failed"))
  }

  columns = [
    {"blocked", "Blocked", "border-amber-500/30", "text-amber-400"},
    {"pending", "Pending", "border-zinc-700", "text-zinc-400"},
    {"in_progress", "In Progress", "border-blue-500/30", "text-blue-400"},
    {"completed", "Done", "border-emerald-500/30", "text-emerald-400"},
    {"failed", "Failed", "border-red-500/30", "text-red-400"}
  ]
%>
<div class="flex flex-col gap-3">
  <%!-- Project selector + progress bar --%>
  <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-3">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="text-xs text-zinc-500">Project:</span>
        <form phx-change="select_project" class="inline">
          <select
            name="project"
            class="bg-zinc-800 border border-zinc-700 rounded px-2 py-1 text-xs text-zinc-300 focus:border-indigo-500 focus:ring-0 focus:outline-none"
          >
            <option :if={map_size(projects) == 0} value="">No projects</option>
            <option :for={{key, _path} <- projects} value={key} selected={key == active_project}>
              {key}
            </option>
          </select>
        </form>
        <button phx-click="toggle_add_project" class="text-xs text-indigo-400 hover:text-indigo-300">
          {if @show_add_project, do: "Cancel", else: "+ Add"}
        </button>
        <button
          :if={active_project && active_project != ""}
          phx-click="trigger_gc"
          phx-value-team={active_project}
          class="text-xs px-2 py-1 rounded bg-red-600/10 text-red-400 hover:bg-red-600/20 transition"
          data-confirm="Run garbage collection on this project?"
        >
          GC
        </button>
        <button phx-click="run_health_check" class="text-xs px-2 py-1 rounded bg-zinc-800 text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 transition">
          Health Check
        </button>
        <button
          phx-click="reset_all_stale"
          class="text-xs px-2 py-1 rounded bg-amber-600/10 text-amber-400 hover:bg-amber-600/20 transition"
          data-confirm="Reset all stale tasks to pending?"
        >
          Reset Stale
        </button>
      </div>

      <div :if={pipeline.total > 0} class="flex items-center gap-3 text-xs text-zinc-500">
        <span class="px-1.5 py-0.5 rounded bg-emerald-500/15 text-emerald-400">{pipeline.completed} done</span>
        <span class="px-1.5 py-0.5 rounded bg-blue-500/15 text-blue-400">{pipeline.in_progress} running</span>
        <span class="px-1.5 py-0.5 rounded bg-zinc-700 text-zinc-400">{pipeline.pending} pending</span>
        <span :if={pipeline.failed > 0} class="px-1.5 py-0.5 rounded bg-red-500/15 text-red-400">{pipeline.failed} failed</span>
      </div>
    </div>

    <%!-- Add project form --%>
    <form :if={@show_add_project} phx-submit="add_project" class="flex items-center gap-2 mt-2">
      <input
        type="text"
        name="path"
        placeholder="Project path (e.g. /Users/.../project)"
        class="flex-1 bg-zinc-800 border border-zinc-700 rounded px-2 py-1 text-xs text-zinc-300 placeholder-zinc-600 focus:border-indigo-500 focus:ring-0 focus:outline-none"
      />
      <button type="submit" class="px-2 py-1 bg-indigo-600/20 text-indigo-400 rounded text-xs hover:bg-indigo-600/30 transition">
        Add
      </button>
    </form>
  </div>

  <%= if tasks == [] do %>
    <.empty_state
      title="No pipeline active"
      description="Add a project with a tasks.jsonl to see the board"
    />
  <% else %>
    <%!-- Kanban Board --%>
    <div class="flex gap-3 overflow-x-auto pb-2">
      <div
        :for={{status, label, border_color, text_color} <- columns}
        :if={kanban[status] != []}
        class={"flex flex-col min-w-[180px] flex-1 max-w-[260px]"}
      >
        <%!-- Column header --%>
        <div class="flex items-center gap-2 mb-2 px-1">
          <span class={"text-[10px] font-semibold uppercase tracking-wider #{text_color}"}>{label}</span>
          <span class="text-[10px] font-mono text-zinc-600">{length(kanban[status])}</span>
        </div>

        <%!-- Task cards --%>
        <div class={"space-y-1.5 max-h-[300px] overflow-y-auto"}>
          <div
            :for={task <- kanban[status]}
            phx-click="select_dag_node"
            phx-value-id={task.id}
            class={[
              "p-2 rounded-lg border cursor-pointer transition hover:bg-zinc-800/60",
              border_color,
              "bg-zinc-900/50",
              @selected_dag_task && @selected_dag_task.id == task.id && "ring-1 ring-indigo-500/50 bg-zinc-800/60"
            ]}
          >
            <div class="flex items-center gap-1.5 mb-1">
              <span class="text-[10px] font-mono text-zinc-600">{task.id}</span>
              <span :if={task.priority} class={"text-[10px] #{priority_color(task.priority)}"}>{task.priority}</span>
            </div>
            <div class="text-xs text-zinc-300 leading-tight line-clamp-2">{task.subject}</div>
            <div :if={task.owner && task.owner != ""} class="mt-1 text-[10px] font-mono text-zinc-500">
              {task.owner}
            </div>
            <div :if={task.blocked_by != []} class="mt-1 flex items-center gap-1">
              <span class="text-[10px] text-amber-500">blocks:</span>
              <span class="text-[10px] font-mono text-zinc-600">{Enum.join(task.blocked_by, ", ")}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%!-- Task Detail (selected) --%>
    <div :if={@selected_dag_task} class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-3">
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-xs font-mono text-zinc-400">#{@selected_dag_task.id}</span>
          <span class={task_badge_class(@selected_dag_task.status)}>{@selected_dag_task.status}</span>
          <span :if={@selected_dag_task.priority} class="text-[10px] text-zinc-500">{@selected_dag_task.priority}</span>
        </div>
        <div class="flex items-center gap-1">
          <button
            phx-click="reassign_swarm_task"
            phx-value-id={@selected_dag_task.id}
            phx-value-owner=""
            class="px-2 py-0.5 text-[10px] bg-zinc-800 text-zinc-400 rounded hover:bg-zinc-700 transition"
          >
            Unassign
          </button>
          <button
            phx-click="reset_swarm_task"
            phx-value-id={@selected_dag_task.id}
            class="px-2 py-0.5 text-[10px] bg-amber-600/10 text-amber-400 rounded hover:bg-amber-600/20 transition"
          >
            Reset
          </button>
        </div>
      </div>
      <div class="text-xs text-zinc-200 mb-1">{@selected_dag_task.subject}</div>
      <div :if={@selected_dag_task[:description]} class="text-xs text-zinc-500 mb-1 line-clamp-3">{@selected_dag_task.description}</div>
      <div class="flex items-center gap-3 text-[10px] text-zinc-600">
        <span :if={@selected_dag_task.owner && @selected_dag_task.owner != ""}>owner: {@selected_dag_task.owner}</span>
        <span :if={@selected_dag_task.blocked_by != []}>blocked by: {Enum.join(@selected_dag_task.blocked_by, ", ")}</span>
        <span :if={@selected_dag_task[:updated]}>updated: {short_timestamp(@selected_dag_task.updated)}</span>
      </div>
    </div>
  <% end %>
</div>
