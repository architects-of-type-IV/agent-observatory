<%!-- Event Detail --%>
<div :if={@selected_event}>
  <% ev = @selected_event %>
  <% {_bg, _border, text_color} = session_color(ev.session_id) %>
  <% {type_label, type_class} = event_type_label(ev.hook_event_type) %>

  <div class="sticky top-0 bg-zinc-900/95 backdrop-blur border-b border-zinc-800 px-3 py-2 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class={"text-[10px] font-mono px-1.5 py-0.5 rounded #{type_class}"}>{type_label}</span>
      <span :if={ev.tool_name} class={"text-xs font-mono #{if is_team_tool?(ev.tool_name), do: "text-cyan-400", else: "text-indigo-400"}"}>{ev.tool_name}</span>
    </div>
    <button phx-click="close_detail" class="text-zinc-600 hover:text-zinc-400 transition p-0.5"><.close_icon /></button>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <p class="text-[11px] text-zinc-300">{ev.summary || event_summary(ev)}</p>
  </div>

  <div :if={is_team_tool?(ev.tool_name)} class="px-3 py-1.5 border-b border-zinc-800/50 bg-cyan-500/5">
    <span class="text-[10px] text-cyan-400 font-mono">Team coordination event</span>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Details</h3>
    <div class="space-y-1">
      <div class="ichor-detail-field">
        <span class="df-label w-16">Timestamp</span>
        <span class="df-value">{Calendar.strftime(ev.inserted_at, "%Y-%m-%d %H:%M:%S.%f")}</span>
      </div>
      <div class="ichor-detail-field">
        <span class="df-label w-16">Event Type</span>
        <span class="df-value">{ev.hook_event_type}</span>
      </div>
      <div class="ichor-detail-field">
        <span class="df-label w-16">Source</span>
        <span class={"df-value #{text_color}"}>{ev.source_app}</span>
      </div>
      <div class="ichor-detail-field">
        <span class="df-label w-16">Session</span>
        <span class="df-value break-all">{ev.session_id}</span>
      </div>
      <div :if={ev.tool_name} class="ichor-detail-field">
        <span class="df-label w-16">Tool</span>
        <span class={"df-value #{if is_team_tool?(ev.tool_name), do: "!text-cyan-400", else: "!text-indigo-400"}"}>{ev.tool_name}</span>
      </div>
      <div :if={ev.tool_use_id} class="ichor-detail-field">
        <span class="df-label w-16">Tool Use ID</span>
        <span class="df-value">{ev.tool_use_id}</span>
      </div>
      <div :if={ev.cwd} class="ichor-detail-field">
        <span class="df-label w-16">Working Dir</span>
        <span class="df-value break-all">{ev.cwd}</span>
      </div>
      <div :if={ev.permission_mode} class="ichor-detail-field">
        <span class="df-label w-16">Permission</span>
        <span class="df-value">{ev.permission_mode}</span>
      </div>
      <div :if={ev.model_name} class="ichor-detail-field">
        <span class="df-label w-16">Model</span>
        <span class="df-value">{ev.model_name}</span>
      </div>
      <div :if={ev.duration_ms} class="ichor-detail-field">
        <span class="df-label w-16">Duration</span>
        <span class={"df-value #{if ev.duration_ms > 5000, do: "!text-amber-400", else: ""}"}>{format_duration(ev.duration_ms)}</span>
      </div>
    </div>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Actions</h3>
    <div class="flex flex-wrap gap-1">
      <button phx-click="filter_session" phx-value-sid={ev.session_id} class="ichor-btn ichor-btn-muted">Filter session</button>
      <button :if={ev.tool_name} phx-click="filter_tool" phx-value-tool={ev.tool_name} class="ichor-btn ichor-btn-muted">Filter tool: {ev.tool_name}</button>
      <button :if={ev.tool_use_id} phx-click="filter_tool_use_id" phx-value-tuid={ev.tool_use_id} class="ichor-btn ichor-btn-muted">Find related</button>
      <button id="copy-payload" phx-hook="CopyToClipboard" data-payload={format_payload(ev.payload)} class="ichor-btn ichor-btn-muted">Copy payload</button>
    </div>
  </div>

  <%!-- Notes --%>
  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Notes</h3>
    <% existing_note = Map.get(@event_notes, ev.id) %>
    <div :if={existing_note} class="mb-2 p-1.5 bg-amber-500/5 border border-amber-500/20 rounded text-[10px]">
      <div class="flex items-center justify-between mb-0.5">
        <span class="text-amber-400 font-semibold text-[9px]">Annotated</span>
        <button phx-click="delete_note" phx-value-event_id={ev.id} class="text-[9px] text-zinc-600 hover:text-red-400 transition">Delete</button>
      </div>
      <p class="text-zinc-300 whitespace-pre-wrap">{existing_note.text}</p>
      <span class="text-zinc-600 text-[9px] mt-0.5 block">{relative_time(existing_note.timestamp, @now)}</span>
    </div>
    <form :if={!existing_note} phx-submit="add_note" class="flex gap-1">
      <input type="hidden" name="event_id" value={ev.id} />
      <input type="text" name="text" placeholder="Add a note..." class="flex-1 ichor-input" />
      <button type="submit" class="ichor-btn bg-amber-600/15 text-amber-400 hover:bg-amber-600/25">Add</button>
    </form>
  </div>

  <div class="px-3 py-2 flex-1">
    <h3 class="ichor-section-title mb-1.5">Payload</h3>
    <pre class="text-[10px] font-mono text-zinc-400 whitespace-pre-wrap break-all overflow-x-auto bg-zinc-950/50 p-2 rounded border border-zinc-800/50">{format_payload(ev.payload)}</pre>
  </div>
</div>

<%!-- Task Detail --%>
<div :if={@selected_task}>
  <% task = @selected_task %>
  <div class="sticky top-0 bg-zinc-900/95 backdrop-blur border-b border-zinc-800 px-3 py-2 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-[10px] font-mono text-zinc-500">Task #{task[:id]}</span>
      <span class={"text-[10px] px-1.5 py-0.5 rounded #{task_status_badge(task[:status])}"}>{task[:status]}</span>
    </div>
    <button phx-click="close_task_detail" class="text-zinc-600 hover:text-zinc-400 transition p-0.5"><.close_icon /></button>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="text-xs font-semibold text-zinc-200 mb-1">{task[:subject]}</h3>
    <p :if={task[:description]} class="text-[10px] text-zinc-500 whitespace-pre-wrap">{task[:description]}</p>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Details</h3>
    <div class="space-y-1">
      <div class="ichor-detail-field">
        <span class="df-label w-16">ID</span>
        <span class="df-value">{task[:id]}</span>
      </div>
      <div class="ichor-detail-field">
        <span class="df-label w-16">Status</span>
        <span class="df-value">{task[:status]}</span>
      </div>
      <div :if={task[:owner]} class="ichor-detail-field">
        <span class="df-label w-16">Owner</span>
        <span class="df-value">{task[:owner]}</span>
      </div>
      <div :if={task[:active_form]} class="ichor-detail-field">
        <span class="df-label w-16">Activity</span>
        <span class="df-value">{task[:active_form]}</span>
      </div>
      <div :if={task[:created_at]} class="ichor-detail-field">
        <span class="df-label w-16">Created</span>
        <span class="df-value">{relative_time(task[:created_at], @now)}</span>
      </div>
    </div>
  </div>

  <div :if={task[:blocked_by] && task[:blocked_by] != []} class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Blocked By</h3>
    <div class="space-y-0.5">
      <div :for={bid <- task[:blocked_by]} class="text-[10px] font-mono text-amber-400">Task #{bid}</div>
    </div>
  </div>

  <div :if={task[:blocks] && task[:blocks] != []} class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Blocks</h3>
    <div class="space-y-0.5">
      <div :for={bid <- task[:blocks]} class="text-[10px] font-mono text-zinc-400">Task #{bid}</div>
    </div>
  </div>

  <div :if={task[:session_id]} class="px-3 py-2">
    <h3 class="ichor-section-title mb-1.5">Actions</h3>
    <div class="flex flex-wrap gap-1">
      <button phx-click="filter_session" phx-value-sid={task[:session_id]} class="ichor-btn ichor-btn-muted">Filter to session</button>
      <button phx-click="jump_to_agents" phx-value-session_id={task[:session_id]} class="ichor-btn ichor-btn-muted">View Agent</button>
    </div>
  </div>
</div>

<%!-- Agent Detail --%>
<div :if={@selected_agent}>
  <% agent = @selected_agent %>
  <% recent_events = agent_recent_events(@events, agent[:agent_id], 15) %>
  <% agent_task_list = agent_tasks(@active_tasks, agent[:agent_id]) %>

  <div class="sticky top-0 bg-zinc-900/95 backdrop-blur border-b border-zinc-800 px-3 py-2 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{member_status_color(agent)}"}></span>
      <span class="text-xs font-semibold text-zinc-200">{agent[:name] || "Agent"}</span>
      <ObservatoryWeb.ObservatoryComponents.model_badge model={agent[:model]} />
    </div>
    <button phx-click="select_agent" phx-value-id={agent[:agent_id]} class="text-zinc-600 hover:text-zinc-400 transition p-0.5"><.close_icon /></button>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Details</h3>
    <div class="space-y-1">
      <div class="ichor-detail-field">
        <span class="df-label w-16">Session</span>
        <span class="df-value break-all">{agent[:agent_id]}</span>
      </div>
      <div :if={agent[:model]} class="ichor-detail-field">
        <span class="df-label w-16">Model</span>
        <span class="df-value">{agent[:model]}</span>
      </div>
      <div :if={agent[:permission_mode]} class="ichor-detail-field">
        <span class="df-label w-16">Permission</span>
        <span class="df-value">{agent[:permission_mode]}</span>
      </div>
      <div :if={agent[:cwd]} class="ichor-detail-field">
        <span class="df-label w-16">CWD</span>
        <span class="df-value break-all">{agent[:cwd]}</span>
      </div>
      <div :if={agent[:uptime]} class="ichor-detail-field">
        <span class="df-label w-16">Uptime</span>
        <span class="df-value">{format_uptime(agent[:uptime])}</span>
      </div>
      <div class="ichor-detail-field">
        <span class="df-label w-16">Type</span>
        <span class="df-value">{agent[:agent_type] || "?"}</span>
      </div>
    </div>
  </div>

  <div :if={agent[:failure_rate] || agent[:health_issues] != []} class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Health Metrics</h3>
    <div class="space-y-1.5">
      <div :if={agent[:failure_rate] && agent[:failure_rate] > 0}>
        <% fail_pct = Float.round(agent[:failure_rate] * 100, 0) %>
        <span class={"ichor-badge #{if fail_pct > 10, do: "ichor-badge-red", else: "ichor-badge-amber"}"}>Failure Rate: {fail_pct}%</span>
      </div>
      <ObservatoryWeb.ObservatoryComponents.health_warnings issues={agent[:health_issues] || []} />
    </div>
  </div>

  <div class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Activity Stream</h3>
    <ObservatoryWeb.Components.AgentActivityComponents.activity_stream events={recent_events} expanded_events={@expanded_events || []} limit={25} now={@now} />
  </div>

  <div :if={agent_task_list != []} class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Assigned Tasks ({length(agent_task_list)})</h3>
    <div class="space-y-1">
      <div :for={task <- agent_task_list} class="ichor-card-compact">
        <div class="flex items-center gap-2 mb-0.5">
          <span class="text-[9px] font-mono text-zinc-600">#{task[:id]}</span>
          <span class={"ichor-badge #{task_status_badge(task[:status])}"}>{task[:status]}</span>
        </div>
        <p class="text-[10px] text-zinc-300">{task[:subject]}</p>
      </div>
    </div>
  </div>

  <div :if={agent[:agent_id]} class="px-3 py-2 border-b border-zinc-800/50">
    <h3 class="ichor-section-title mb-1.5">Send Message</h3>
    <div phx-update="ignore" id={"agent-msg-form-#{agent[:agent_id]}"} phx-hook="ClearFormOnSubmit">
      <form phx-submit="send_agent_message" class="flex gap-1">
        <input type="hidden" name="session_id" value={agent[:agent_id]} />
        <input type="text" name="content" placeholder="Message to agent..." class="flex-1 ichor-input" />
        <button type="submit" class="ichor-btn ichor-btn-primary">Send</button>
      </form>
    </div>
  </div>

  <div :if={agent[:agent_id]} class="px-3 py-2">
    <h3 class="ichor-section-title mb-1.5">Actions</h3>
    <div class="flex flex-wrap gap-1">
      <button phx-click="focus_agent" phx-value-session_id={agent[:agent_id]} class="ichor-btn ichor-btn-primary">Focus</button>
      <button phx-click="filter_session" phx-value-sid={agent[:agent_id]} class="ichor-btn ichor-btn-muted">Filter to session</button>
      <button phx-click="set_view" phx-value-mode="feed" class="ichor-btn ichor-btn-muted">View Feed</button>
    </div>
  </div>
</div>
