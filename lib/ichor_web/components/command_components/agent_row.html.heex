<div
  phx-click="select_command_agent"
  phx-value-id={@agent.agent_id}
  class={[
    "flex items-center gap-3 px-3 py-1.5 cursor-pointer hover:bg-raised/50 transition",
    if(@selected && (@selected[:agent_id] || @selected[:session_id]) == @agent.agent_id,
      do: "bg-raised/80 border-l-2 border-interactive",
      else: "border-l-2 border-transparent"
    )
  ]}
>
  <%!-- Status dot --%>
  <span class={["w-2 h-2 rounded-full shrink-0", status_dot_color(@agent.status)]} />

  <%!-- Name --%>
  <span class="text-xs font-medium text-high w-24 truncate">{@agent.name}</span>

  <%!-- Current tool or idle --%>
  <div class="text-xs w-28 truncate">
    <%= if @agent.current_tool do %>
      <% %{tool_name: tool, elapsed: elapsed} = @agent.current_tool %>
      <span class="text-interactive font-mono">{tool}</span>
      <span class="text-muted font-mono">{elapsed}s</span>
    <% else %>
      <span class="text-muted italic">--</span>
    <% end %>
  </div>

  <%!-- Model --%>
  <span class="text-[10px] font-mono text-muted w-12 truncate">{short_model(@agent.model)}</span>

  <%!-- Event count --%>
  <span class="text-[10px] font-mono text-muted w-10 text-right">{@agent.event_count}e</span>

  <%!-- Tool count --%>
  <span class="text-[10px] font-mono text-muted w-8 text-right">
    {if is_integer(@agent.tool_count), do: @agent.tool_count, else: 0}t
  </span>

  <%!-- Source app --%>
  <span class="text-[10px] font-mono text-muted ml-auto">{@agent.source_app}</span>
</div>
