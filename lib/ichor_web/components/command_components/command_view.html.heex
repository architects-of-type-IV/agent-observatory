<% agent_index = assigns[:agent_index] || %{}

all_agents =
  agent_index
  |> Map.values()
  |> Enum.uniq_by(fn a -> a[:session_id] || a[:agent_id] end)
  |> Enum.reject(fn a -> a[:agent_id] == "operator" end)
  |> Enum.sort_by(fn a -> {status_sort_val(a[:status]), a[:name] || ""} end)

total_agents = length(all_agents)

names = FH.name_map(@teams, all_agents)
pipeline_state = assigns[:pipeline_state] || %{}
watched_projects = Map.get(pipeline_state, :watched_projects, [])

mailbox_messages = assigns[:mailbox_messages] || []
comms_filter = assigns[:comms_team_filter]
agent_filter = assigns[:comms_agent_filter] || []

filtered_messages =
  mailbox_messages
  |> FH.filter_by_team(comms_filter, @teams)
  |> FH.filter_by_agents(agent_filter, names)

selected = @selected_command_agent %>
<div class="flex h-full">
  <%!-- Left: Agent List --%>
  <div class="w-[280px] shrink-0 border-r border-border bg-base/30 flex flex-col overflow-hidden">
    <div class="px-2.5 py-1.5 border-b border-border flex items-center justify-between shrink-0">
      <h3 class="text-[10px] font-semibold text-low uppercase tracking-wider">Fleet</h3>
      <span class="text-[9px] text-muted">{total_agents} agents</span>
    </div>
    <div class="flex-1 overflow-y-auto">
      <%= for agent <- all_agents do %>
        <% is_selected = selected && selected[:agent_id] == agent[:agent_id] %>
        <div
          class={"flex items-center gap-1.5 px-2.5 py-1.5 cursor-pointer transition border-l-2 #{if is_selected, do: "bg-interactive/10 border-interactive", else: "border-transparent hover:bg-raised/20"}"}
          phx-click="select_command_agent"
          phx-value-id={agent[:agent_id]}
        >
          <.status_dot color={status_dot_color(agent[:status] || :idle)} />
          <span class="text-[11px] text-high truncate flex-1">
            {agent[:name] || agent[:agent_id]}
          </span>
          <span
            :if={agent[:team_name] && agent[:team_name] != ""}
            class="text-[8px] text-muted font-mono shrink-0"
          >
            {agent[:team_name]}
          </span>
          <span class={"text-[9px] font-mono shrink-0 #{if agent[:tmux_session], do: "text-brand", else: "text-error"}"}>
            {if agent[:tmux_session], do: "tmux", else: "no-tmux"}
          </span>
          <span class="text-[9px] text-interactive">
            {short_model(agent[:model])}
          </span>
        </div>
      <% end %>

      <.empty_panel :if={all_agents == []} title="No agents detected" description="Start a Claude session to see it here." class="px-3 py-8" />
    </div>
  </div>

  <%!-- Center: Comms Timeline --%>
  <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
    <%!-- Command bar --%>
    <div class="px-3 py-1.5 border-b border-border bg-base/30 shrink-0">
      <div class="flex gap-1.5 flex-wrap">
        <form
          phx-submit="send_targeted_message"
          id="command-msg-form"
          class="flex gap-1 flex-1 min-w-0"
        >
          <div id="target-select-stable" phx-update="ignore">
            <select name="target" class="ichor-select shrink-0">
              <option value="">Target...</option>
              <optgroup label="Broadcast">
                <option value="all">All Agents</option>
                <%= for team <- @teams do %>
                  <option value={"team:#{team.name}"}>Team: {team.name}</option>
                <% end %>
              </optgroup>
              <optgroup label="Agents">
                <%= for agent <- all_agents do %>
                  <option value={agent[:agent_id]}>
                    {agent[:name]}{if agent[:team_name], do: " (#{agent[:team_name]})", else: ""}
                  </option>
                <% end %>
              </optgroup>
            </select>
          </div>
          <div
            id="cmd-input-stable"
            phx-update="ignore"
            phx-hook="ClearFormOnSubmit"
            class="flex-1 min-w-0"
          >
            <.input name="content" placeholder="Message..." class="w-full" />
          </div>
          <.button type="submit" variant="primary" class="shrink-0">Send</.button>
        </form>
        <form phx-submit="launch_session" class="flex gap-1 shrink-0">
          <div id="project-select-stable" phx-update="ignore">
            <select name="cwd" class="ichor-select">
              <option value="">Project...</option>
              <%= for {key, path} <- watched_projects do %>
                <option value={path}>{key}</option>
              <% end %>
            </select>
          </div>
          <.button type="submit" variant="success" class="shrink-0">Launch</.button>
        </form>
      </div>
    </div>

    <%!-- Tab bar: Comms / Feed --%>
    <% active_tab = assigns[:activity_tab] || :comms %>
    <div class="px-3 py-1 border-b border-border flex items-center justify-between shrink-0">
      <div class="flex gap-2">
        <span
          phx-click="set_sub_tab"
          phx-value-screen="activity"
          phx-value-tab="comms"
          class={"text-[10px] font-semibold uppercase tracking-wider cursor-pointer transition #{if active_tab == :comms, do: "text-interactive", else: "text-muted hover:text-default"}"}
        >
          Comms
        </span>
        <span
          phx-click="set_sub_tab"
          phx-value-screen="activity"
          phx-value-tab="feed"
          class={"text-[10px] font-semibold uppercase tracking-wider cursor-pointer transition #{if active_tab == :feed, do: "text-interactive", else: "text-muted hover:text-default"}"}
        >
          Feed
        </span>
      </div>
      <div :if={active_tab == :comms} class="flex gap-1">
        <span
          phx-click="set_comms_filter"
          phx-value-team=""
          class={"text-[9px] px-1.5 py-0.5 rounded cursor-pointer transition #{if !comms_filter, do: "bg-interactive/15 text-interactive", else: "text-low hover:text-high"}"}
        >
          All
        </span>
        <%= for team <- @teams do %>
          <span
            phx-click="set_comms_filter"
            phx-value-team={team.name}
            class={"text-[9px] px-1.5 py-0.5 rounded cursor-pointer transition #{if comms_filter == team.name, do: "bg-interactive/15 text-interactive", else: "text-low hover:text-high"}"}
          >
            {team.name}
          </span>
        <% end %>
        <span class="text-[9px] text-muted ml-1">{length(filtered_messages)} msgs</span>
        <%= if agent_filter != [] do %>
          <span class="w-px h-3 bg-highlight mx-1" />
          <span class="text-[9px] text-violet font-semibold">Trace:</span>
          <%= for af <- agent_filter do %>
            <span
              phx-click="trace_agent"
              phx-value-agent_id={af}
              class="text-[9px] px-1.5 py-0.5 rounded bg-violet/15 text-violet cursor-pointer hover:bg-violet/25 transition"
            >
              {FH.resolve_label(af, names)}
            </span>
          <% end %>
          <button
            phx-click="clear_trace"
            class="text-[9px] text-muted hover:text-default cursor-pointer ml-0.5"
          >
            x
          </button>
        <% end %>
      </div>
      <div :if={active_tab == :feed} class="flex gap-1">
        <button
          phx-click="expand_all"
          class="text-[9px] px-1.5 py-0.5 rounded text-low hover:text-high cursor-pointer transition"
        >
          Expand
        </button>
        <button
          phx-click="collapse_all"
          class="text-[9px] px-1.5 py-0.5 rounded text-low hover:text-high cursor-pointer transition"
        >
          Collapse
        </button>
        <span class="text-[9px] text-muted ml-1">{length(@feed_groups)} sessions</span>
      </div>
    </div>

    <%!-- Comms: Message timeline --%>
    <div :if={active_tab == :comms} class="flex-1 overflow-y-auto">
      <%= if filtered_messages == [] do %>
        <div class="flex-1 flex items-center justify-center p-6">
          <div class="text-center max-w-xs">
            <p class="text-[11px] text-low mb-2">No messages yet</p>
            <p class="text-[10px] text-muted leading-relaxed">
              Send a message from the command bar above, or use the MCP API.
            </p>
          </div>
        </div>
      <% else %>
        <div class="divide-y divide-border/30">
          <%= for msg <- filtered_messages do %>
            <% from_label = FH.resolve_label(msg.from, names) %>
            <% to_label = FH.resolve_label(msg.to, names) %>
            <% is_operator = msg.from == "operator" || msg.from == "dashboard" %>
            <div class={"px-4 py-2.5 hover:bg-raised/20 transition #{if is_operator, do: "border-l-2 border-brand/30", else: ""}"}>
              <div class="flex items-center gap-2 mb-1">
                <span class={"text-[10px] font-semibold #{if is_operator, do: "text-brand", else: "text-high"}"}>
                  {from_label}
                </span>
                <svg
                  class="w-3 h-3 text-muted shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13 7l5 5m0 0l-5 5m5-5H6"
                  />
                </svg>
                <span class={"text-[10px] font-semibold #{if msg.to == "operator", do: "text-brand", else: "text-high"}"}>
                  {to_label}
                </span>
                <span class="flex-1" />
                <.status_badge
                  label={if msg.read, do: "read", else: "unread"}
                  color={if msg.read, do: "muted", else: "brand"}
                />
                <%= case msg[:transport] do %>
                  <% :mcp -> %>
                    <.status_badge label="mcp" color="interactive" />
                  <% :operator -> %>
                    <.status_badge label="operator" color="brand" />
                  <% :hook -> %>
                    <.status_badge label="hook" color="warning" />
                  <% _ -> %>
                    <.status_badge label="http" color="success" />
                <% end %>
                <span class="text-[9px] text-muted font-mono tabular-nums">
                  {FH.format_timestamp(msg.timestamp)}
                </span>
              </div>
              <p class="text-[11px] text-default leading-relaxed pl-0.5">{msg.content}</p>
              <div class="flex items-center gap-3 mt-1 pl-0.5">
                <span class="flex items-center gap-1">
                  <span class="w-1 h-1 rounded-full bg-success" />
                  <span class="text-[9px] text-muted">mailbox</span>
                </span>
                <span :if={msg.type && msg.type != :text} class="text-[9px] text-muted">
                  {msg.type}
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%!-- Feed: Turn-based live activity --%>
    <div :if={active_tab == :feed} class="flex-1 overflow-y-auto p-2">
      <.feed_view
        feed_groups={@feed_groups}
        visible_events={@visible_events}
        selected_event={@selected_event}
        event_notes={@event_notes}
        expanded_sessions={@expanded_sessions}
        now={@now}
      />
    </div>
  </div>

  <%!-- Right: Detail Panel (400px, conditional) --%>
  <% sel_id = selected && (selected[:agent_id] || selected[:name])
  sel_agent = sel_id && Map.get(agent_index, sel_id, selected) %>
  <div
    :if={selected && sel_id}
    class="w-[400px] shrink-0 border-l border-border bg-base/30 flex flex-col overflow-hidden"
  >
    <.agent_detail_panel
      agent={sel_agent}
      agent_id={sel_id}
      teams={@teams}
      messages={mailbox_messages}
      paused={false}
      names={names}
      agent_filter={agent_filter}
    />
  </div>
</div>
