<% alerts = build_alerts(@issues, @stale) %>
<div
  :if={alerts != []}
  class="bg-base/50 border border-border rounded-lg p-3 max-h-48 overflow-y-auto"
>
  <h3 class="text-xs font-semibold text-low uppercase tracking-wider mb-2">Alerts</h3>
  <div class="space-y-1">
    <div
      :for={alert <- alerts}
      class="flex items-center gap-2 text-xs py-1"
    >
      <span class={[
        "w-1.5 h-1.5 rounded-full shrink-0",
        severity_color(alert.severity)
      ]} />
      <span class={severity_text_color(alert.severity)}>{alert.message}</span>
      <button
        :if={alert.action}
        phx-click={alert.action}
        phx-value-id={alert.target_id}
        class="ml-auto px-1.5 py-0.5 bg-raised text-default rounded hover:bg-highlight transition"
      >
        {alert.action_label}
      </button>
    </div>
  </div>
</div>
