<div class="bg-base/50 border border-border rounded-lg p-4">
  <div class="flex items-center justify-between gap-4">
    <%!-- Health indicator --%>
    <div class="flex items-center gap-3">
      <div class={[
        "flex items-center gap-2 px-3 py-1.5 rounded-md text-sm font-medium",
        if(@health.healthy,
          do: "bg-success/15 text-success border border-success/30",
          else: "bg-error/15 text-error border border-error/30"
        )
      ]}>
        <span class={[
          "w-2 h-2 rounded-full",
          if(@health.healthy, do: "bg-success", else: "bg-error animate-pulse")
        ]} />
        <%= if @health.healthy do %>
          Healthy
        <% else %>
          {length(@health.issues)} issues
        <% end %>
      </div>

      <%!-- Project selector --%>
      <div :if={map_size(@projects) > 0} class="flex items-center gap-2">
        <span class="text-xs text-low">Pipeline:</span>
        <form phx-change="select_dag_project" class="inline">
          <.stable_select id="select-project" name="project" class="ichor-select text-xs py-1">
            <option :for={{key, _path} <- @projects} value={key} selected={key == @active_project}>
              {key}
            </option>
          </.stable_select>
        </form>
      </div>
    </div>

    <%!-- Pipeline progress --%>
    <div :if={@pipeline.total > 0} class="flex-1 max-w-md">
      <div class="flex items-center justify-between text-xs text-low mb-1">
        <span>{@pipeline.completed}/{@pipeline.total} tasks</span>
        <span>{@progress_pct}%</span>
      </div>
      <div class="h-2.5 bg-raised rounded-full overflow-hidden">
        <div
          class="h-full bg-success rounded-full transition-all duration-500"
          style={"width: #{@progress_pct}%"}
        />
      </div>
    </div>

    <%!-- Action buttons --%>
    <div class="flex items-center gap-2">
      <button
        :if={length(@stale) > 0}
        phx-click="reset_dag_stale"
        class="px-2 py-1 bg-brand/20 text-brand rounded text-xs hover:bg-brand/30 transition"
      >
        Reset {length(@stale)} stuck tasks
      </button>
      <button
        phx-click="run_dag_health_check"
        class="px-2 py-1 bg-highlight text-high rounded text-xs hover:bg-highlight transition"
      >
        Check Health
      </button>
    </div>
  </div>
</div>
