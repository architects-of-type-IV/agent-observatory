<% tasks = @pipeline_state.tasks
active_project = @pipeline_state.active_project
projects = @pipeline_state.watched_projects
pipeline_graph = @pipeline_state.dag

# Group tasks by status for kanban columns
kanban = %{
  "blocked" => Enum.filter(tasks, &(&1.status == "blocked")),
  "pending" => Enum.filter(tasks, &(&1.status == "pending")),
  "in_progress" => Enum.filter(tasks, &(&1.status == "in_progress")),
  "completed" => Enum.filter(tasks, &(&1.status == "completed")),
  "failed" => Enum.filter(tasks, &(&1.status == "failed"))
}

columns = [
  {"blocked", "Blocked", "border-brand/30", "text-brand"},
  {"pending", "Pending", "border-border-subtle", "text-default"},
  {"in_progress", "In Progress", "border-info/30", "text-info"},
  {"completed", "Done", "border-success/30", "text-success"},
  {"failed", "Failed", "border-error/30", "text-error"}
]

task_map = Map.new(tasks, &{&1.id, &1})
waves = pipeline_graph.waves
critical_path = MapSet.new(pipeline_graph.critical_path) %>
<div class="flex gap-0 h-full">
  <%!-- Left Sidebar: Projects + Stats + Task Detail --%>
  <div class="w-[240px] shrink-0 flex flex-col gap-3 bg-base/30 border-r border-border p-3 overflow-x-hidden overflow-y-auto">
    <%!-- Projects --%>
    <div>
      <div class="flex flex-col gap-2">
        <span class="text-[10px] text-muted uppercase tracking-wider">Projects</span>
        <div class="flex flex-wrap gap-1">
          <span :for={{key, _path} <- projects} class="ichor-badge ichor-badge-zinc font-mono">
            {key}
          </span>
          <span :if={map_size(projects) == 0} class="text-[10px] text-muted">
            Auto-detecting...
          </span>
        </div>
        <div class="flex flex-wrap gap-1">
          <button
            :if={active_project && active_project != ""}
            phx-click="trigger_pipeline_gc"
            phx-value-team={active_project}
            class="ichor-btn ichor-btn-danger"
            data-confirm="Run garbage collection on this project?"
          >
            GC
          </button>
          <button phx-click="run_pipeline_health_check" class="ichor-btn ichor-btn-muted">
            Health
          </button>
          <button
            phx-click="reset_pipeline_stale"
            class="ichor-btn bg-brand/15 text-brand hover:bg-brand/25"
            data-confirm="Reset all stale tasks to pending?"
          >
            Reset Stale
          </button>
        </div>
      </div>
    </div>

    <%!-- Task Detail (selected) --%>
    <div :if={@selected_pipeline_task} class="ichor-card p-3 min-w-0 overflow-hidden">
      <span class="text-[10px] text-muted uppercase tracking-wider">Task Detail</span>
      <div class="flex items-center gap-2 flex-wrap mt-2 mb-2">
        <span
          :if={@selected_pipeline_task[:project]}
          class="text-[10px] font-mono text-violet truncate"
        >
          {@selected_pipeline_task.project}
        </span>
        <span class="text-xs font-mono text-default">#{@selected_pipeline_task.id}</span>
        <span class={task_badge_class(@selected_pipeline_task.status)}>
          {@selected_pipeline_task.status}
        </span>
        <span :if={@selected_pipeline_task.priority} class="text-[10px] text-low">
          {@selected_pipeline_task.priority}
        </span>
      </div>
      <div class="text-xs text-high mb-1 break-words">{@selected_pipeline_task.subject}</div>
      <div :if={@selected_pipeline_task[:description]} class="text-xs text-low mb-2 break-words">
        {@selected_pipeline_task.description}
      </div>
      <div class="flex flex-col gap-1 text-[10px] text-muted mb-2 break-all">
        <span
          :if={@selected_pipeline_task.owner && @selected_pipeline_task.owner != ""}
          class="truncate"
        >
          owner: {@selected_pipeline_task.owner}
        </span>
        <span :if={@selected_pipeline_task.blocked_by != []} class="truncate">
          blocked by: {Enum.join(@selected_pipeline_task.blocked_by, ", ")}
        </span>
        <span :if={@selected_pipeline_task[:updated]}>
          updated: {short_timestamp(@selected_pipeline_task.updated)}
        </span>
      </div>
      <div class="flex flex-wrap gap-1">
        <button
          phx-click="reassign_pipeline_task"
          phx-value-id={@selected_pipeline_task.id}
          phx-value-owner=""
          class="ichor-btn ichor-btn-muted"
        >
          Unassign
        </button>
        <button
          phx-click="heal_pipeline_task"
          phx-value-id={@selected_pipeline_task.id}
          class="ichor-btn bg-brand/15 text-brand hover:bg-brand/25"
        >
          Reset
        </button>
      </div>
    </div>
  </div>

  <%!-- Right: Kanban + DAG --%>
  <div class="flex flex-col gap-3 min-w-0 flex-1 overflow-y-auto p-3">
    <%= if tasks == [] do %>
      <.empty_state
        title="No pipeline active"
        description="Projects with tasks.jsonl are auto-detected from session events"
      />
    <% else %>
      <%!-- Kanban Board --%>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-2">
        <div
          :for={{status, label, border_color, text_color} <- columns}
          :if={kanban[status] != []}
          class="flex flex-col ichor-kanban-col"
        >
          <div class="flex items-center gap-2 mb-1.5 px-0.5">
            <h6 class={text_color}>{label}</h6>
            <span class="text-[9px] font-mono text-muted">{length(kanban[status])}</span>
          </div>

          <div class="space-y-1 max-h-[280px] overflow-y-auto pr-0.5">
            <div
              :for={task <- kanban[status]}
              phx-click="select_pipeline_task"
              phx-value-id={task.id}
              class={[
                "ichor-card-compact cursor-pointer",
                border_color,
                @selected_pipeline_task && @selected_pipeline_task.id == task.id &&
                  "!ring-1 !ring-interactive/50 !bg-raised/60"
              ]}
            >
              <div class="flex items-center gap-1 mb-0.5">
                <span
                  :if={task[:project] && task.project != ""}
                  class="text-[9px] font-mono text-violet/60"
                >
                  {task.project}
                </span>
                <span class="text-[9px] font-mono text-muted">{task.id}</span>
                <span :if={task.priority} class={"text-[9px] #{priority_color(task.priority)}"}>
                  {task.priority}
                </span>
              </div>
              <div class="text-[10px] text-high leading-tight line-clamp-2">{task.subject}</div>
              <div
                :if={task.owner && task.owner != ""}
                class="mt-0.5 text-[9px] font-mono text-low"
              >
                {task.owner}
              </div>
              <div :if={task.blocked_by != []} class="mt-0.5 flex items-center gap-1">
                <span class="text-[9px] text-brand">blocks:</span>
                <span class="text-[9px] font-mono text-muted">
                  {Enum.join(task.blocked_by, ", ")}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%!-- Pipeline Dependency Graph --%>
      <div
        :if={waves != []}
        class="border border-border/60 rounded-md p-3 overflow-x-auto bg-base/20"
      >
        <h3 class="text-[10px] font-semibold text-muted uppercase tracking-wider mb-2">
          Dependency Graph
          <span
            :if={pipeline_graph.critical_path != []}
            class="text-muted normal-case font-normal ml-2"
          >
            Critical path: {length(pipeline_graph.critical_path)} tasks
          </span>
        </h3>
        <div class="flex gap-6 overflow-x-auto pb-2 min-h-[120px]">
          <div
            :for={{wave, wave_idx} <- Enum.with_index(waves)}
            class="flex flex-col gap-2 min-w-[140px]"
          >
            <div class="text-[10px] text-muted uppercase tracking-wider mb-1 text-center">
              Wave {wave_idx}
            </div>
            <.task_node
              :for={task_id <- wave}
              task={Map.get(task_map, task_id)}
              task_id={task_id}
              is_critical={MapSet.member?(critical_path, task_id)}
              is_selected={@selected_pipeline_task && @selected_pipeline_task.id == task_id}
            />
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
