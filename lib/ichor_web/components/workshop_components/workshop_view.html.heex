<% wc = IchorWeb.Components.WorkshopComponents
selected = wc.find_agent(@ws_agents, @ws_selected_agent)
tree = wc.spawn_tree_html(@ws_agents, @ws_spawn_links) %>
<div class="h-full -m-2 flex flex-col overflow-hidden">
  <%!-- Presets bar --%>
  <div class="flex items-center px-2 py-1 border-b border-border gap-2 shrink-0">
    <div class="flex items-center rounded overflow-hidden border border-border-subtle/60">
      <span class="text-[10px] text-muted px-1.5 py-1 bg-raised/80">Presets</span>
      <%= for p <- Ichor.Control.Presets.ui_list() do %>
        <button
          phx-click="ws_preset"
          phx-value-name={p.name}
          class={"text-[10px] px-2 py-1 bg-#{p.color}/10 text-#{p.color} hover:bg-#{p.color}/20 transition cursor-pointer"}
        >
          {p.label}
        </button>
      <% end %>
      <button
        phx-click="ws_clear"
        class="text-[10px] px-2 py-1 bg-error/10 text-error hover:bg-error/20 transition cursor-pointer"
      >
        Clear
      </button>
    </div>
    <span class="flex-1" />
    <span class="text-[10px] text-muted">
      Drag green ports for spawn hierarchy, cyan ports for comm rules
    </span>
  </div>

  <div class="flex flex-1 overflow-hidden">
    <%!-- Canvas area --%>
    <div class="flex-1 flex flex-col overflow-hidden">
      <%!-- Canvas toolbar --%>
      <div class="px-3 py-1.5 border-b border-border flex items-center gap-2 bg-base/30 shrink-0">
        <h3 class="text-[10px] font-semibold text-low uppercase tracking-wider">Team Builder</h3>
        <span class="w-px h-3 bg-raised" />
        <%= if @ws_agent_types != [] do %>
          <div class="flex items-center gap-0.5">
            <%= for type <- @ws_agent_types do %>
              <button
                phx-click="ws_add_agent_from_type"
                phx-value-id={type.id}
                class="ichor-btn ichor-btn-muted text-[9px] flex items-center gap-1 cursor-pointer"
                title={"Add #{type.name} agent"}
              >
                <span
                  class="w-[5px] h-[5px] rounded-full shrink-0"
                  style={"background: #{wc.cap_dot(type.capability)}"}
                /> + {type.name}
              </button>
            <% end %>
          </div>
        <% else %>
          <button phx-click="ws_add_agent" class="ichor-btn ichor-btn-success">+ Agent</button>
        <% end %>
        <span class="flex-1" />
        <span class="text-[10px] text-low">
          <span class="font-bold text-high">{length(@ws_agents)}</span>
          agents <span class="mx-1 text-muted">|</span>
          <span>{length(@ws_spawn_links)}</span>
          spawn links <span class="mx-1 text-muted">|</span>
          <span>{length(@ws_comm_rules)}</span>
          comm rules
        </span>
      </div>

      <%!-- Canvas with JS hook --%>
      <div
        id="workshop-canvas-hook"
        phx-hook="WorkshopCanvas"
        phx-update="ignore"
        class="flex-1 relative overflow-auto"
        style="background: hsl(var(--ichor-bg)); background-image: radial-gradient(circle, hsl(var(--ichor-border-subtle) / 0.15) 1px, transparent 1px); background-size: 24px 24px;"
      >
        <svg
          class="ws-lines"
          style="position:absolute;inset:0;pointer-events:none;z-index:1;"
          width="100%"
          height="100%"
        >
        </svg>
        <div class="ws-canvas" style="position:relative;min-width:100%;min-height:100%;">
          <div
            :if={@ws_agents == []}
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center pointer-events-none"
          >
            <div class="text-xs font-medium text-low mb-1">
              Click "+ Agent" or use a preset to start
            </div>
            <div class="text-[10px] text-muted leading-relaxed">
              Add agents, then draw spawn hierarchy and communication links<br />using the green (spawn) and cyan (comm) ports on each node.
            </div>
          </div>
        </div>
      </div>
    </div>

    <%!-- Right panel --%>
    <div class="w-[320px] shrink-0 border-l border-border bg-base/30 flex flex-col overflow-hidden">
      <div class="flex-1 overflow-y-auto">
        <%!-- Team config --%>
        <div class="px-3 py-2.5 border-b border-border/50">
          <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider mb-2">
            Team Configuration
          </h4>
          <form phx-change="ws_update_team" phx-submit="ws_update_team" class="space-y-2">
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Team Name
              </label>
              <input
                type="text"
                class="w-full ichor-input"
                value={@ws_team_name}
                name="name"
                phx-debounce="300"
              />
            </div>
            <div class="flex gap-2">
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                  Strategy
                </label>
                <select class="w-full ichor-select" name="strategy">
                  <option value="one_for_one" selected={@ws_strategy == "one_for_one"}>
                    one_for_one
                  </option>
                  <option value="rest_for_one" selected={@ws_strategy == "rest_for_one"}>
                    rest_for_one
                  </option>
                  <option value="one_for_all" selected={@ws_strategy == "one_for_all"}>
                    one_for_all
                  </option>
                </select>
              </div>
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                  Default Model
                </label>
                <select class="w-full ichor-select" name="default_model">
                  <option value="sonnet" selected={@ws_default_model == "sonnet"}>sonnet</option>
                  <option value="opus" selected={@ws_default_model == "opus"}>opus</option>
                  <option value="haiku" selected={@ws_default_model == "haiku"}>haiku</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Project / CWD
              </label>
              <input
                type="text"
                class="w-full ichor-input font-mono"
                value={@ws_cwd}
                name="cwd"
                phx-debounce="300"
              />
            </div>
          </form>
        </div>

        <%!-- Selected agent config --%>
        <div :if={selected} class="px-3 py-2.5 border-b border-border/50">
          <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider mb-2">
            Agent Configuration
          </h4>
          <form phx-change="ws_update_agent" phx-submit="ws_update_agent" class="space-y-2">
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Name
              </label>
              <input
                type="text"
                class="w-full ichor-input"
                value={selected.name}
                name="name"
                phx-debounce="300"
              />
            </div>
            <div class="flex gap-2">
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                  Capability
                </label>
                <select class="w-full ichor-select" name="capability">
                  <option
                    :for={cap <- ~w(builder scout reviewer lead coordinator)}
                    value={cap}
                    selected={selected.capability == cap}
                  >
                    {cap}
                  </option>
                </select>
              </div>
              <div class="flex-1">
                <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                  Model
                </label>
                <select class="w-full ichor-select" name="model">
                  <option
                    :for={m <- ~w(sonnet opus haiku)}
                    value={m}
                    selected={selected.model == m}
                  >
                    {m}
                  </option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Permission Mode
              </label>
              <select class="w-full ichor-select" name="permission">
                <option
                  :for={p <- ~w(default plan dangerously_skip)}
                  value={p}
                  selected={selected.permission == p}
                >
                  {p}
                </option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Persona / System Prompt
              </label>
              <textarea
                class="w-full ichor-input"
                rows="3"
                name="persona"
                phx-debounce="500"
                placeholder="You are a focused backend engineer..."
              >{selected.persona}</textarea>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                File Scope (one per line)
              </label>
              <textarea
                class="w-full ichor-input font-mono"
                rows="2"
                name="file_scope"
                phx-debounce="500"
                placeholder="lib/ichor/fleet/&#10;lib/ichor_web/live/"
              >{selected.file_scope}</textarea>
            </div>
            <div>
              <label class="block text-[10px] font-semibold text-low uppercase tracking-wider mb-1">
                Quality Gates (one per line)
              </label>
              <textarea
                class="w-full ichor-input font-mono"
                rows="2"
                name="quality_gates"
                phx-debounce="500"
                placeholder="mix compile --warnings-as-errors"
              >{selected.quality_gates}</textarea>
            </div>
          </form>
          <button phx-click="ws_remove_agent" class="w-full ichor-btn ichor-btn-danger mt-2">
            Remove Agent
          </button>
        </div>

        <%!-- Spawn hierarchy tree --%>
        <div class="px-3 py-2.5 border-b border-border/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider">
              Spawn Hierarchy
            </h4>
            <span class="text-[9px] text-muted">who spawns who</span>
          </div>
          <%= if tree == [] do %>
            <div class="text-[10px] text-muted">
              {if @ws_agents == [],
                do: "No agents yet",
                else: "Draw spawn links to build hierarchy"}
            </div>
          <% else %>
            <div class="space-y-0.5">
              <%= for {{node, depth}, _idx} <- Enum.with_index(tree) do %>
                <div class="flex items-center gap-1 group" style={"padding-left: #{depth * 16}px"}>
                  <span :if={depth > 0} class="text-[9px] text-muted font-mono w-3">&boxur;</span>
                  <span
                    class="w-[5px] h-[5px] rounded-full shrink-0"
                    style={"background: #{wc.cap_dot(node.capability)}"}
                  />
                  <span class="text-[10px] text-high flex-1">{node.name}</span>
                  <span class={"text-[7px] font-bold uppercase px-1 py-0.5 rounded #{wc.cap_badge(node.capability)}"}>
                    {wc.cap_abbr(node.capability)}
                  </span>
                  <%!-- Find spawn link index for removal (child nodes only) --%>
                  <% link_idx =
                    if depth > 0,
                      do: Enum.find_index(@ws_spawn_links, fn l -> l.to == node.id end) %>
                  <button
                    :if={link_idx}
                    phx-click="ws_remove_spawn_link"
                    phx-value-index={link_idx}
                    class="text-muted hover:text-error opacity-0 group-hover:opacity-100 cursor-pointer text-[10px]"
                    title="Remove spawn link"
                  >
                    &times;
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%!-- Comm rules --%>
        <div class="px-3 py-2.5 border-b border-border/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider">
              Communication Rules
            </h4>
            <span class="text-[9px] text-muted">{length(@ws_comm_rules)} rules</span>
          </div>
          <%= if @ws_comm_rules == [] do %>
            <div class="text-[10px] text-muted">No communication rules yet.</div>
          <% else %>
            <div class="space-y-1">
              <%= for {rule, idx} <- Enum.with_index(@ws_comm_rules) do %>
                <% from = wc.find_agent(@ws_agents, rule.from) %>
                <% to = wc.find_agent(@ws_agents, rule.to) %>
                <% via = if rule.via, do: wc.find_agent(@ws_agents, rule.via) %>
                <div :if={from && to} class="flex items-center gap-1.5 text-[10px]">
                  <span class={"text-[9px] px-1.5 py-0.5 rounded #{wc.comm_tag_class(rule.policy)}"}>
                    {rule.policy}
                  </span>
                  <span class="text-high">{from.name}</span>
                  <span class="text-muted">&rarr;</span>
                  <span class="text-high">{to.name}</span>
                  <span :if={via} class="text-[9px] text-violet">via {via.name}</span>
                  <span class="flex-1" />
                  <button
                    phx-click="ws_remove_comm_rule"
                    phx-value-index={idx}
                    class="text-muted hover:text-error cursor-pointer text-[10px]"
                  >
                    &times;
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
          <div class="text-[9px] text-muted mt-2">
            Drag cyan ports between agents to add rules
          </div>
        </div>

        <%!-- Saved Blueprints --%>
        <div class="px-3 py-2.5 border-b border-border/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider">
              Saved Blueprints
            </h4>
            <div class="flex gap-1">
              <button
                :if={@ws_blueprint_id}
                phx-click="ws_new_blueprint"
                class="ichor-btn ichor-btn-muted text-[9px]"
              >
                New
              </button>
              <button
                :if={@ws_agents != []}
                phx-click="ws_save_blueprint"
                class="ichor-btn ichor-btn-muted text-[9px]"
              >
                {if @ws_blueprint_id, do: "Update", else: "Save"}
              </button>
            </div>
          </div>
          <%= if @ws_blueprints == [] do %>
            <div class="text-[10px] text-muted">No saved blueprints yet.</div>
          <% else %>
            <div class="space-y-1">
              <%= for bp <- @ws_blueprints do %>
                <div class={"flex items-center gap-1.5 text-[10px] px-2 py-1.5 rounded group #{if @ws_blueprint_id && @ws_blueprint_id == bp.id, do: "bg-cyan/10 border border-cyan/20", else: "bg-raised/50 hover:bg-raised"}"}>
                  <span class="text-high truncate flex-1">{bp.name}</span>
                  <span class="text-[9px] text-muted">{length(bp.agent_blueprints)} agents</span>
                  <button
                    phx-click="ws_load_blueprint"
                    phx-value-id={bp.id}
                    class="text-cyan hover:text-cyan opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]"
                  >
                    load
                  </button>
                  <button
                    phx-click="ws_delete_blueprint"
                    phx-value-id={bp.id}
                    class="text-error hover:text-error opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]"
                    data-confirm={"Delete blueprint \"#{bp.name}\"?"}
                  >
                    del
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%!-- Agent Types --%>
        <div class="px-3 py-2.5 border-b border-border/50">
          <div class="flex items-center justify-between mb-2">
            <h4 class="text-[10px] font-semibold text-low uppercase tracking-wider">
              Agent Types
            </h4>
            <button
              phx-click="ws_edit_type_new"
              class="ichor-btn ichor-btn-muted text-[9px] cursor-pointer"
            >
              + New Type
            </button>
          </div>

          <%!-- Type list --%>
          <%= if @ws_agent_types == [] do %>
            <div class="text-[10px] text-muted">No agent types defined yet.</div>
          <% else %>
            <div class="space-y-1">
              <%= for type <- @ws_agent_types do %>
                <div class={"flex items-center gap-1.5 text-[10px] px-2 py-1.5 rounded group #{if @ws_editing_type && @ws_editing_type != :new && @ws_editing_type.id == type.id, do: "bg-cyan/10 border border-cyan/20", else: "bg-raised/50 hover:bg-raised"}"}>
                  <span
                    class="w-[5px] h-[5px] rounded-full shrink-0"
                    style={"background: #{wc.cap_dot(type.capability)}"}
                  />
                  <span class="text-high truncate flex-1">{type.name}</span>
                  <span class={"text-[7px] font-bold uppercase px-1 py-0.5 rounded #{wc.cap_badge(type.capability)}"}>
                    {wc.cap_abbr(type.capability)}
                  </span>
                  <span class="text-[9px] text-muted">{type.default_model}</span>
                  <button
                    phx-click="ws_edit_type"
                    phx-value-id={type.id}
                    class="text-cyan hover:text-cyan opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]"
                  >
                    edit
                  </button>
                  <button
                    phx-click="ws_delete_type"
                    phx-value-id={type.id}
                    class="text-error hover:text-error opacity-0 group-hover:opacity-100 cursor-pointer text-[9px]"
                    data-confirm={"Delete type \"#{type.name}\"?"}
                  >
                    del
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>

          <%!-- Edit/Create form --%>
          <%= if @ws_editing_type do %>
            <% is_new = @ws_editing_type == :new %>
            <% t =
              if is_new,
                do: %{
                  name: "",
                  capability: "builder",
                  default_model: "sonnet",
                  default_permission: "default",
                  default_persona: "",
                  default_file_scope: "",
                  default_quality_gates: "mix compile --warnings-as-errors"
                },
                else: @ws_editing_type %>
            <form
              phx-submit="ws_save_type"
              class="mt-2 space-y-1.5 p-2 rounded bg-raised/70 border border-border-subtle/40"
            >
              <div class="text-[10px] font-semibold text-default mb-1">
                {if is_new, do: "New Agent Type", else: "Edit: #{t.name}"}
              </div>
              <div>
                <label class="block text-[9px] text-low mb-0.5">Name</label>
                <input
                  type="text"
                  name="name"
                  value={t.name}
                  class="w-full ichor-input text-[10px]"
                  required
                />
              </div>
              <div class="flex gap-1.5">
                <div class="flex-1">
                  <label class="block text-[9px] text-low mb-0.5">Capability</label>
                  <select name="capability" class="w-full ichor-select text-[10px]">
                    <option
                      :for={cap <- ~w(builder scout reviewer lead coordinator)}
                      value={cap}
                      selected={t.capability == cap}
                    >
                      {cap}
                    </option>
                  </select>
                </div>
                <div class="flex-1">
                  <label class="block text-[9px] text-low mb-0.5">Model</label>
                  <select name="default_model" class="w-full ichor-select text-[10px]">
                    <option
                      :for={m <- ~w(sonnet opus haiku)}
                      value={m}
                      selected={t.default_model == m}
                    >
                      {m}
                    </option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-[9px] text-low mb-0.5">Permission</label>
                <select name="default_permission" class="w-full ichor-select text-[10px]">
                  <option
                    :for={p <- ~w(default plan dangerously_skip)}
                    value={p}
                    selected={t.default_permission == p}
                  >
                    {p}
                  </option>
                </select>
              </div>
              <div>
                <label class="block text-[9px] text-low mb-0.5">Persona</label>
                <textarea
                  name="default_persona"
                  rows="2"
                  class="w-full ichor-input text-[10px]"
                  phx-debounce="500"
                >{t.default_persona}</textarea>
              </div>
              <div>
                <label class="block text-[9px] text-low mb-0.5">File Scope</label>
                <textarea
                  name="default_file_scope"
                  rows="1"
                  class="w-full ichor-input font-mono text-[10px]"
                  phx-debounce="500"
                >{t.default_file_scope}</textarea>
              </div>
              <div>
                <label class="block text-[9px] text-low mb-0.5">Quality Gates</label>
                <textarea
                  name="default_quality_gates"
                  rows="1"
                  class="w-full ichor-input font-mono text-[10px]"
                  phx-debounce="500"
                >{t.default_quality_gates}</textarea>
              </div>
              <div class="flex gap-1 pt-1">
                <button
                  type="submit"
                  class="ichor-btn ichor-btn-success text-[9px] flex-1 cursor-pointer"
                >
                  {if is_new, do: "Create", else: "Save"}
                </button>
                <button
                  type="button"
                  phx-click="ws_cancel_edit_type"
                  class="ichor-btn ichor-btn-muted text-[9px] cursor-pointer"
                >
                  Cancel
                </button>
              </div>
            </form>
          <% end %>
        </div>

        <%!-- Launch --%>
        <div :if={@ws_agents != []} class="px-3 py-2.5">
          <button
            phx-click="ws_launch_team"
            class="w-full ichor-btn ichor-btn-success text-xs py-2"
            data-confirm={"Launch team \"#{@ws_team_name}\" with #{length(@ws_agents)} agents?"}
          >
            Launch Team
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
