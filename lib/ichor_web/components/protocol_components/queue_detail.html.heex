<%
  detail = @stats[:queue_detail] || []
  agent_name_map = build_agent_name_map(@teams)
%>
<div>
  <div class="px-2 py-1.5 border-b border-border/50">
    <h5 class="text-[9px] font-semibold uppercase tracking-wider text-low">
      Queue <span class="text-muted normal-case font-normal">{length(detail)} sessions</span>
    </h5>
  </div>
  <%= if detail == [] do %>
    <p class="text-[9px] text-muted px-2 py-2">No pending commands</p>
  <% else %>
    <div>
      <div :for={entry <- detail}>
        <%
          key = "queue:#{entry.session_id}"
          expanded = MapSet.member?(@expanded_items, key)
          session_label = resolve_agent_label(entry.session_id, agent_name_map)
        %>
        <div
          class="px-2 py-1 flex items-center gap-1.5 cursor-pointer hover:bg-raised/30 transition"
          phx-click="toggle_protocol_item"
          phx-value-id={key}
        >
          <svg class={"w-2.5 h-2.5 text-muted transition-transform #{if expanded, do: "rotate-90"}"} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <div class="flex-1 min-w-0">
            <span class="text-[9px] font-mono text-default truncate" title={entry.session_id}>{session_label}</span>
          </div>
          <span class={"text-[9px] tabular-nums #{if entry.pending_count > 0, do: "text-brand font-semibold", else: "text-muted"}"}>
            {entry.pending_count} pending
          </span>
        </div>
        <%= if expanded do %>
          <div class="px-5 pb-1.5 pt-0.5">
            <%= if (entry[:pending_commands] || []) == [] do %>
              <div class="text-[9px] text-muted">No command files</div>
            <% else %>
              <div class="space-y-px">
                <div :for={cmd <- entry[:pending_commands] || []} class="flex gap-1.5 py-0.5">
                  <span class="w-1 h-1 rounded-full mt-1 shrink-0 bg-brand-muted"></span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-1">
                      <span class="text-[9px] font-mono text-default">{cmd.type}</span>
                      <span class="text-[9px] text-muted">from</span>
                      <span class="text-[9px] font-mono text-default">{resolve_agent_label(cmd.from, agent_name_map)}</span>
                    </div>
                    <p class="text-[9px] text-low truncate">{cmd.content}</p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
