<%
  recent = @stats[:recent_traces] || []
  agent_name_map = build_agent_name_map(@teams)
%>
<div>
  <div class="px-2 py-1.5 border-b border-border/50">
    <h5 class="text-[9px] font-semibold uppercase tracking-wider text-low">
      Traces <span class="text-muted normal-case font-normal">{@stats[:traces] || 0}</span>
    </h5>
  </div>
  <%= if recent == [] do %>
    <p class="text-[9px] text-muted px-2 py-2">No traces yet</p>
  <% else %>
    <div>
      <div :for={trace <- recent}>
        <%
          key = "trace:#{trace.id}"
          expanded = MapSet.member?(@expanded_items, key)
        %>
        <div
          class="px-2 py-1 flex items-center gap-1.5 cursor-pointer hover:bg-raised/30 transition"
          phx-click="toggle_protocol_item"
          phx-value-id={key}
        >
          <svg class={"w-2.5 h-2.5 text-muted transition-transform #{if expanded, do: "rotate-90"}"} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <span class={"text-[9px] px-1 py-0 rounded #{trace_type_color(trace.type)}"}>{trace_type_label(trace.type)}</span>
          <div class="flex-1 min-w-0 flex items-baseline gap-1 truncate">
            <span class="text-[9px] font-mono text-default">{resolve_agent_label(trace.from, agent_name_map)}</span>
            <span class="text-[9px] text-muted">-></span>
            <span class="text-[9px] font-mono text-default">{resolve_agent_label(trace.to, agent_name_map)}</span>
          </div>
          <span class={"w-1.5 h-1.5 rounded-full shrink-0 #{hop_status_color(trace.last_status)}"}></span>
        </div>
        <%= if expanded do %>
          <div class="px-5 pb-1.5 pt-0.5">
            <%= if trace.content_preview && trace.content_preview != "" do %>
              <p class="text-[9px] text-low mb-0.5">{trace.content_preview}</p>
            <% end %>
            <div class="flex gap-3 text-[9px]">
              <span class="text-muted">{trace.hop_count} hops</span>
              <span class={hop_status_text(trace.last_status)}>{trace.last_status}</span>
              <span class="text-muted">{format_timestamp(trace.timestamp)}</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
