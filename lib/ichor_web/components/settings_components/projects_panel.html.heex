<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h2 class="text-[11px] font-semibold text-high uppercase tracking-wider">Projects</h2>
    <button
      phx-click="settings_project_event"
      phx-value-action="new"
      class="ichor-btn text-[10px] px-2 py-1"
    >
      + Add Project
    </button>
  </div>

  <%!-- Create/Edit form --%>
  <%= if @settings_project_form do %>
    <div class="bg-raised border border-border rounded p-3">
      <.form
        for={@settings_project_form}
        phx-change="settings_project_event"
        phx-submit="settings_project_event"
      >
        <input type="hidden" name="action" value="validate" />

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] text-muted mb-1">Name</label>
            <input
              type="text"
              name="settings_project[name]"
              value={Phoenix.HTML.Form.input_value(@settings_project_form, :name)}
              class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
              placeholder="My Project"
            />
          </div>

          <div>
            <label class="block text-[10px] text-muted mb-1">Active</label>
            <label class="flex items-center gap-2 mt-1">
              <input
                type="checkbox"
                name="settings_project[is_active]"
                value="true"
                checked={Phoenix.HTML.Form.input_value(@settings_project_form, :is_active) in [true, "true"]}
                class="rounded border-border bg-base text-interactive focus:ring-interactive"
              />
              <span class="text-[10px] text-default">Enabled</span>
            </label>
          </div>
        </div>

        <.inputs_for :let={loc} field={@settings_project_form[:location]}>
          <div class="mt-3">
            <label class="block text-[10px] text-muted mb-1">Location Type</label>
            <select
              name={loc[:type].name}
              class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
            >
              <option value="local" selected={to_string(loc[:type].value) == "local"}>Local</option>
              <option value="remote" selected={to_string(loc[:type].value) == "remote"}>Remote</option>
            </select>
          </div>

          <div class="mt-3">
            <label class="block text-[10px] text-muted mb-1">Path</label>
            <div class="flex gap-2">
              <input
                type="text"
                name={loc[:path].name}
                value={@browsed_path || loc[:path].value}
                class="flex-1 bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
                placeholder="/path/to/project"
              />
              <button
                type="button"
                phx-click="settings_project_event"
                phx-value-action="browse"
                class="ichor-btn text-[10px] px-2 py-1"
              >
                Browse
              </button>
            </div>
          </div>

          <%!-- Server-side folder browser --%>
          <%= if @folder_browser do %>
            <div class="mt-2 bg-base border border-border rounded overflow-hidden">
              <%!-- Breadcrumb nav --%>
              <div class="flex items-center gap-1 px-2 py-1.5 border-b border-border-subtle bg-raised/50 overflow-x-auto">
                <%= for crumb <- @folder_browser.breadcrumbs do %>
                  <button
                    type="button"
                    phx-click="settings_project_event"
                    phx-value-action="browse_navigate"
                    phx-value-path={crumb}
                    class={"text-[10px] hover:text-interactive transition shrink-0 #{if crumb == @folder_browser.current, do: "text-high font-medium", else: "text-muted"}"}
                  >
                    {Path.basename(crumb)}/
                  </button>
                <% end %>
              </div>

              <%!-- Filter input --%>
              <div class="px-2 py-1 border-b border-border-subtle">
                <input
                  type="text"
                  name="filter"
                  value={@folder_browser.filter}
                  placeholder="Filter folders..."
                  phx-keyup="settings_project_event"
                  phx-value-action="browse_filter"
                  class="w-full bg-base border border-border-subtle rounded px-2 py-0.5 text-[10px] text-high focus:border-interactive focus:outline-none"
                  autocomplete="off"
                  phx-debounce="100"
                />
              </div>

              <%!-- Directory listing --%>
              <% filtered = filtered_entries(@folder_browser.entries, @folder_browser.filter) %>
              <div class="max-h-48 overflow-y-auto">
                <%= if Enum.empty?(filtered) do %>
                  <div class="px-3 py-4 text-center text-muted text-[10px]">No matching subdirectories</div>
                <% end %>
                <%= for entry <- filtered do %>
                  <button
                    type="button"
                    phx-click="settings_project_event"
                    phx-value-action="browse_navigate"
                    phx-value-path={Path.join(@folder_browser.current, entry)}
                    class="w-full text-left px-3 py-1 text-[11px] text-default hover:bg-raised hover:text-high transition flex items-center gap-1.5"
                  >
                    <svg class="w-3 h-3 text-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                    </svg>
                    {entry}
                  </button>
                <% end %>
              </div>

              <%!-- Actions --%>
              <div class="flex items-center justify-between px-2 py-1.5 border-t border-border-subtle bg-raised/50">
                <span class="text-[10px] text-muted font-mono truncate">{@folder_browser.current}</span>
                <div class="flex gap-2 shrink-0">
                  <button
                    type="button"
                    phx-click="settings_project_event"
                    phx-value-action="browse_close"
                    class="ichor-btn-muted text-[10px] px-2 py-0.5"
                  >
                    Cancel
                  </button>
                  <button
                    type="button"
                    phx-click="settings_project_event"
                    phx-value-action="browse_select"
                    class="ichor-btn text-[10px] px-2 py-0.5"
                  >
                    Select
                  </button>
                </div>
              </div>
            </div>
          <% end %>

          <%!-- Remote-only fields --%>
          <%= if to_string(loc[:type].value) in ["remote", "Remote"] do %>
            <div class="grid grid-cols-3 gap-3 mt-3">
              <div>
                <label class="block text-[10px] text-muted mb-1">Host</label>
                <input
                  type="text"
                  name={loc[:host].name}
                  value={loc[:host].value}
                  class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
                  placeholder="192.168.1.100"
                />
              </div>

              <div>
                <label class="block text-[10px] text-muted mb-1">Port</label>
                <input
                  type="number"
                  name={loc[:port].name}
                  value={loc[:port].value || 22}
                  class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
                />
              </div>

              <div>
                <label class="block text-[10px] text-muted mb-1">Username</label>
                <input
                  type="text"
                  name={loc[:username].name}
                  value={loc[:username].value}
                  class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
                  placeholder="deploy"
                />
              </div>
            </div>

            <div class="mt-3">
              <label class="block text-[10px] text-muted mb-1">Auth Method</label>
              <select
                name={loc[:auth_method].name}
                class="w-full bg-base border border-border rounded px-2 py-1 text-[11px] text-high focus:border-interactive focus:outline-none"
              >
                <option value="ssh_key" selected={to_string(loc[:auth_method].value) == "ssh_key"}>SSH Key</option>
                <option value="password" selected={to_string(loc[:auth_method].value) == "password"}>Password</option>
              </select>
            </div>
          <% end %>
        </.inputs_for>

        <div class="flex gap-2 mt-4">
          <button type="submit" name="action" value="save" class="ichor-btn text-[10px] px-3 py-1">Save</button>
          <button
            type="button"
            phx-click="settings_project_event"
            phx-value-action="cancel"
            class="ichor-btn-muted text-[10px] px-3 py-1"
          >
            Cancel
          </button>
        </div>
      </.form>
    </div>
  <% end %>

  <%!-- Projects table --%>
  <div class="bg-raised border border-border rounded overflow-hidden">
    <table class="w-full text-[11px]">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Name</th>
          <th class="text-left px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Repo</th>
          <th class="text-left px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Type</th>
          <th class="text-left px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Path</th>
          <th class="text-left px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Status</th>
          <th class="text-right px-3 py-2 text-[10px] font-semibold text-low uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody>
        <%= if Enum.empty?(@settings_projects) do %>
          <tr>
            <td colspan="6" class="px-3 py-6 text-center text-muted text-[11px]">
              No projects configured. Click "+ Add Project" to get started.
            </td>
          </tr>
        <% end %>
        <%= for project <- @settings_projects do %>
          <tr class="border-b border-border-subtle hover:bg-base/50 transition">
            <td class="px-3 py-2 text-high font-medium">{project.name}</td>
            <td class="px-3 py-2 text-default text-[10px]">
              <%= if project.repo_name do %>
                <span class="text-default">{project.repo_name}</span>
              <% else %>
                <span class="text-muted/40">--</span>
              <% end %>
            </td>
            <td class="px-3 py-2 text-default">
              <span class={"px-1.5 py-0.5 rounded text-[10px] #{if project.location.type == :local, do: "bg-info/15 text-info", else: "bg-brand/15 text-brand"}"}>
                {project.location.type}
              </span>
            </td>
            <td class="px-3 py-2 text-muted font-mono text-[10px]">{truncate_path(project.location.path)}</td>
            <td class="px-3 py-2">
              <span class={"w-1.5 h-1.5 rounded-full inline-block #{if project.is_active, do: "bg-success", else: "bg-muted"}"} />
              <span class="text-default ml-1">{if project.is_active, do: "Active", else: "Inactive"}</span>
            </td>
            <td class="px-3 py-2 text-right space-x-2">
              <button
                phx-click="settings_project_event"
                phx-value-action="edit"
                phx-value-id={project.id}
                class="text-interactive hover:text-high transition text-[10px]"
              >
                Edit
              </button>
              <button
                phx-click="settings_project_event"
                phx-value-action="delete"
                phx-value-id={project.id}
                class="text-error/70 hover:text-error transition text-[10px]"
                data-confirm="Delete this project?"
              >
                Delete
              </button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
